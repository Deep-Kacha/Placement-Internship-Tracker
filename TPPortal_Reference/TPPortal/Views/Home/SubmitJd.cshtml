@{
    ViewData["Title"] = "Submit JD";
    Layout = "_AuthLayout";
}

<section class="bg-gray-100 min-h-screen py-12">
    <div class="max-w-4xl mx-auto px-6">

        <!-- Header -->
        <div class="text-center mb-8">
            <h2 class="text-2xl font-bold text-gray-800">Campus Placement Registration</h2>
            <p class="text-gray-500 text-sm mt-2">RK University, Rajkot – Training & Placement Cell</p>
        </div>

        <form id="jdForm" onsubmit="return validateCompanyRegistration(event)" class="space-y-6">

            <!-- Contact Information -->
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="bg-red-600 text-white w-7 h-7 flex items-center justify-center rounded-full text-sm">
                        <i class="fas fa-address-book"></i>
                    </div>
                    <h2 class="text-md font-semibold text-gray-700">Contact Information</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                    <div class="bg-gray-100 p-4 rounded-lg">
                        <p class="font-semibold">Dr. Vishal Doshi</p>
                        <p class="text-sm text-gray-600">Head of Training & Placement Cell</p>
                        <p class="text-sm">+91 98765 43210</p>
                    </div>
                    <div class="bg-gray-100 p-4 rounded-lg">
                        <p class="font-semibold">Mr. Osho Shah</p>
                        <p class="text-sm text-gray-600">Assistant Training & Placement Officer</p>
                        <p class="text-sm">+91 87654 32109</p>
                    </div>
                </div>
            </div>

            <!-- Company Details -->
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="bg-red-600 text-white w-7 h-7 flex items-center justify-center rounded-full text-sm">
                        <i class="fas fa-building"></i>
                    </div>
                    <h2 class="text-md font-semibold text-gray-700">Company Details</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                        <input type="email" id="compEmail" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('compEmail')" />
                        <p id="compEmailError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Company Name *</label>
                        <input type="text" id="compName" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('compName')" />
                        <p id="compNameError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Job Location *</label>
                        <input type="text" id="compLocation" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('compLocation')" />
                        <p id="compLocationError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Company Website *</label>
                        <input type="url" id="compWebsite" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('compWebsite')" />
                        <p id="compWebsiteError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Short Company Description</label>
                        <textarea id="compDesc" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" rows="3" oninput="validateCompField('compDesc')"></textarea>
                        <p id="compDescError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                </div>
            </div>

            <!-- Job Role & Compensation -->
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="bg-red-600 text-white w-7 h-7 flex items-center justify-center rounded-full text-sm">
                        <i class="fas fa-briefcase"></i>
                    </div>
                    <h2 class="text-md font-semibold text-gray-700">Job Role & Compensation</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Job Position *</label>
                        <input type="text" id="jobPos" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('jobPos')" />
                        <p id="jobPosError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Annual CTC *</label>
                        <input type="text" id="jobCtc" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('jobCtc')" />
                        <p id="jobCtcError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Internship Duration</label>
                        <input type="text" id="jobInternship" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('jobInternship')" />
                        <p id="jobInternshipError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Stipend</label>
                        <input type="text" id="jobStipend" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('jobStipend')" />
                        <p id="jobStipendError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Bond</label>
                        <input type="text" id="jobBond" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Date of Joining *</label>
                        <input type="date" id="jobDate" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" onchange="validateCompField('jobDate')" />
                        <p id="jobDateError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                </div>
            </div>

            <!-- Eligibility -->
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="bg-red-600 text-white w-7 h-7 flex items-center justify-center rounded-full text-sm">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h2 class="text-md font-semibold text-gray-700">Eligibility Criteria</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <p class="font-semibold text-sm mb-2">Eligible Batch *</p>
                        <div class="flex flex-wrap gap-3">
                            @foreach (var b in new[] { "2025", "2024", "2023" }) { 
                                <label class="flex items-center gap-2 text-sm">
                                    <input type="checkbox" value="@b" class="batch-chk" onchange="validateCompField('batch')" /> @b
                                </label> 
                            }
                        </div>
                        <p id="batchError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <p class="font-semibold text-sm mb-2">Eligible Courses *</p>
                        <div class="flex flex-wrap gap-3">
                            @foreach (var c in new[] { "B.Tech CS", "B.Tech IT", "Mechanical", "Civil", "Electrical", "BCA", "MCA", "MBA" }) { 
                                <label class="flex items-center gap-2 text-sm">
                                    <input type="checkbox" value="@c" class="course-chk" onchange="validateCompField('course')" /> @c
                                </label> 
                            }
                        </div>
                        <p id="courseError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                </div>
            </div>

            <!-- Selection Process -->
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="bg-red-600 text-white w-7 h-7 flex items-center justify-center rounded-full text-sm">
                        <i class="fas fa-clipboard-list"></i>
                    </div>
                    <h2 class="text-md font-semibold text-gray-700">Selection Process</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Selection Process *</label>
                        <textarea id="selProcess" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" rows="3" oninput="validateCompField('selProcess')"></textarea>
                        <p id="selProcessError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Campus Drive Date *</label>
                        <input type="date" id="selDate" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" onchange="validateCompField('selDate')" />
                        <p id="selDateError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Registration Link (Optional)</label>
                        <input type="url" id="selLink" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('selLink')" />
                        <p id="selLinkError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                </div>
            </div>

            <!-- Contact Person -->
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="bg-red-600 text-white w-7 h-7 flex items-center justify-center rounded-full text-sm">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <h2 class="text-md font-semibold text-gray-700">Contact Person Details</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Contact Name *</label>
                        <input type="text" id="contName" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('contName')" />
                        <p id="contNameError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Contact Email *</label>
                        <input type="email" id="contEmail" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('contEmail')" />
                        <p id="contEmailError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Contact Mobile *</label>
                        <input type="text" id="contMobile" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" oninput="validateCompField('contMobile')" />
                        <p id="contMobileError" class="text-red-500 text-xs mt-1 hidden"></p>
                    </div>
                </div>
            </div>

            <!-- Upload Documents -->
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="bg-red-600 text-white w-7 h-7 flex items-center justify-center rounded-full text-sm">
                        <i class="fas fa-upload"></i>
                    </div>
                    <h2 class="text-md font-semibold text-gray-700">Upload Documents</h2>
                </div>
                <div class="border-2 border-dashed border-gray-300 rounded-xl p-10 text-center hover:border-red-400 transition cursor-pointer">
                    <p class="text-gray-500 mb-3">Drop files here or click to browse</p>
                    <input type="file" id="uploadDoc" accept=".pdf,.doc,.docx" class="mb-2 w-full max-w-xs mx-auto" onchange="validateCompField('uploadDoc')" />
                    <p id="uploadDocError" class="text-red-500 text-xs mt-1 hidden"></p>
                </div>
            </div>

            <!-- Additional Details -->
            <div class="bg-white rounded-xl shadow-sm border p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="bg-red-600 text-white w-7 h-7 flex items-center justify-center rounded-full text-sm">
                        <i class="fas fa-info-circle"></i>
                    </div>
                    <h2 class="text-md font-semibold text-gray-700">Additional Details</h2>
                </div>
                <textarea id="addDetails" class="w-full p-3 border rounded-lg outline-none focus:ring-2 focus:ring-red-500" rows="4" placeholder="Any additional information or special requirements"></textarea>
            </div>

            <!-- Buttons -->
            <div class="flex flex-col items-center gap-3 pb-6 mt-2">
                <div class="flex flex-col sm:flex-row justify-center gap-4 w-full sm:w-auto">
                    <button type="button" onclick="clearCompanyRegistration()" class="px-10 py-3 border border-gray-300 rounded-lg font-medium hover:bg-gray-50 transition w-full sm:w-auto bg-white cursor-pointer">Clear Form</button>
                    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-10 py-3 rounded-lg font-medium shadow transition w-full sm:w-auto border-none cursor-pointer">Submit Form</button>
                </div>
                <p class="text-xs text-gray-400 mt-3 text-center max-w-md mx-auto px-4 sm:px-0">After registration, admin will verify your details and eligibility. After verification you will receive further instructions.</p>
            </div>

        </form>
    </div>
</section>