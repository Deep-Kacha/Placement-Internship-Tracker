@{ ViewData["Title"] = "Student Dashboard"; }

<div class="w-full">
    <header class="page-header flex justify-between items-start">
        <div>
            <h1 class="page-title">Welcome Bhavesh - 2023CS001</h1>
            <p class="page-subtitle">Here's your placement dashboard overview</p>
        </div>
    </header>

    <!-- Status Cards -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        <div class="bg-[#ece6da] p-6 rounded-lg border border-[#e0dacd] shadow-sm">
            <div class="flex justify-between items-start mb-5">
                <div class="text-2xl p-2.5 bg-[#d8cfc3] rounded-lg">✅</div>
                <span class="font-bold text-sm px-2 py-1 rounded text-green-700 bg-[#e8f5e9]">APPROVED</span>
            </div>
            <h3 class="m-0 text-xl font-bold text-gray-800">T&P Status</h3>
            <p class="mt-1 text-sm text-gray-500 m-0">Registration Approved</p>
        </div>
        <div class="bg-[#ece6da] p-6 rounded-lg border border-[#e0dacd] shadow-sm">
            <div class="flex justify-between items-start mb-5">
                <div class="text-2xl p-2.5 bg-[#d8cfc3] rounded-lg">💼</div>
                <span class="font-bold text-sm px-2 py-1 rounded text-blue-700 bg-blue-100">3</span>
            </div>
            <h3 class="m-0 text-xl font-bold text-gray-800">Applied</h3>
            <p class="mt-1 text-sm text-gray-500 m-0">Job Applications</p>
        </div>
        <div class="bg-[#ece6da] p-6 rounded-lg border border-[#e0dacd] shadow-sm">
            <div class="flex justify-between items-start mb-5">
                <div class="text-2xl p-2.5 bg-[#d8cfc3] rounded-lg">🗓️</div>
                <span class="font-bold text-sm px-2 py-1 rounded text-orange-700 bg-orange-100">2</span>
            </div>
            <h3 class="m-0 text-xl font-bold text-gray-800">Interviews</h3>
            <p class="mt-1 text-sm text-gray-500 m-0">Scheduled</p>
        </div>
    </section>

    <!-- Quick Actions -->
    <section>
        <h2 class="text-2xl font-bold mb-5 text-gray-800">Quick Actions</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
            @foreach (var action in new[] {
                new { Title = "Browse Jobs", Desc = "Explore available opportunities", Link = "View Jobs", Href = "/StudJobs", Icon = "🔍" },
                new { Title = "My Applied", Desc = "Track application status", Link = "View Applied", Href = "/StudApplications", Icon = "📋" },
                new { Title = "Profile", Desc = "Update your information", Link = "Edit Profile", Href = "/StudProfile", Icon = "👤" },
                new { Title = "Interviews", Desc = "Manage interview schedule", Link = "View Schedule", Href = "/StudInterviewSchedule", Icon = "🗓️" }
            })
            {
                <a href="@action.Href" class="bg-[#ece6da] border border-[#e0dacd] p-6 rounded-lg cursor-pointer hover:shadow-md transition flex flex-col items-center text-center no-underline text-inherit">
                    <div class="w-16 h-16 bg-[#e9e2d5] rounded-full flex items-center justify-center mb-4 text-3xl">@action.Icon</div>
                    <h3 class="text-lg font-bold my-2 text-gray-800">@action.Title</h3>
                    <p class="text-gray-500 text-sm mb-5 leading-snug w-full">@action.Desc</p>
                    <span class="text-[#e7000b] font-semibold text-sm mt-auto">@action.Link ➔</span>
                </a>
            }
        </div>
    </section>
</div>
