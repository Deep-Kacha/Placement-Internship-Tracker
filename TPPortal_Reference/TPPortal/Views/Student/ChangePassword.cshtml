@{ ViewData["Title"] = "Change Password"; }

<div class="w-full">
    <header class="page-header flex justify-between items-start mb-8">
        <div>
            <h1 class="page-title">Change Password</h1>
            <p class="page-subtitle">Update your account password for better security.</p>
        </div>
    </header>

    <div class="flex justify-center">
        <form onsubmit="return validateChangePassword(event)" class="bg-[#ece6da] border-[1.5px] border-[#e7000b] p-6 md:p-8 rounded-xl shadow-sm w-full max-w-lg">
            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-800 mb-2">Current Password</label>
                <div class="relative">
                    <input type="password" id="currentPassword" name="current" class="w-full p-3 rounded-lg border border-[#e0d8cc] outline-none text-gray-800 bg-white focus:border-[#e7000b]" placeholder="Enter current password" oninput="validateFieldRealtime('current')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'currentPassword')">Show</button>
                </div>
                <p id="currentError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-800 mb-2">New Password</label>
                <div class="relative">
                    <input type="password" id="newPassword" name="new" class="w-full p-3 rounded-lg border border-[#e0d8cc] outline-none text-gray-800 bg-white focus:border-[#e7000b]" placeholder="Enter new password" oninput="validateFieldRealtime('new')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'newPassword')">Show</button>
                </div>
                <p id="newError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-800 mb-2">Confirm New Password</label>
                <div class="relative">
                    <input type="password" id="confirmPassword" name="confirm" class="w-full p-3 rounded-lg border border-[#e0d8cc] outline-none text-gray-800 bg-white focus:border-[#e7000b]" placeholder="Re-Enter new password" oninput="validateFieldRealtime('confirm')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'confirmPassword')">Show</button>
                </div>
                <p id="confirmError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <div class="bg-white border border-[#e0d8cc] p-4 rounded-lg mb-5 text-sm">
                <p class="font-bold text-gray-800 mb-2">Password requirements:</p>
                <ul class="space-y-1 text-gray-500 list-none p-0">
                    <li>✔ At least 8 characters long</li>
                    <li>✔ Contains uppercase and lowercase letters</li>
                    <li>✔ Contains at least one number</li>
                    <li>✔ Contains at least one special character</li>
                </ul>
            </div>

            <!-- Forgot Password Link -->
            <div class="text-right text-sm mb-5">
                <a href="/StudForgotPassword" class="text-[#3498db] font-semibold hover:underline no-underline">Forgot Password?</a>
            </div>

            <!-- Update Button -->
            <button type="submit" class="w-full bg-[#e7000b] text-white py-3 rounded-lg mb-3 font-bold uppercase transition-all hover:bg-red-700 border-none cursor-pointer">Update Password</button>

            <!-- Cancel Button -->
            <button type="button" onclick="history.back()" class="w-full bg-transparent border border-gray-400 text-gray-800 py-3 rounded-lg font-bold uppercase transition-all hover:bg-gray-100 cursor-pointer">Cancel</button>
        </form>
    </div>
</div>
