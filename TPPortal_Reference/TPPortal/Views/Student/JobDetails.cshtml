@{ ViewData["Title"] = "Job Details"; }

<div class="w-full">
    <div class="page-header">
        <h1 class="page-title">Company Job Description</h1>
        <p class="page-subtitle">Read All Information Properly Before Apply</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Section -->
        <div class="lg:col-span-2 space-y-6">

            <!-- Header Card -->
            <div class="bg-[#ece6da] p-6 rounded-lg border border-[#e0dacd] shadow-sm flex items-center gap-6">
                <div class="w-16 h-16 bg-blue-500 rounded-xl shadow-sm flex items-center justify-center shrink-0 text-white font-bold text-3xl">T</div>
                <div>
                    <h2 class="text-2xl font-bold text-gray-900 m-0 mb-2">Software Development Engineer</h2>
                    <div class="flex flex-wrap items-center gap-4 text-sm text-gray-700 font-medium">
                        <div class="flex items-center gap-1.5"><span class="text-blue-600">🏢</span> TechCorp Solutions</div>
                        <div class="flex items-center gap-1.5"><span class="text-blue-600">📍</span> Bangalore, India</div>
                        <div class="flex items-center gap-1.5"><span class="text-blue-600">🌐</span> <a href="https://www.techcorp.com" target="_blank" rel="noopener noreferrer" class="hover:underline text-gray-700 no-underline">www.techcorp.com</a></div>
                    </div>
                </div>
            </div>

            <!-- Metrics -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                <div class="bg-[#eafdf0] rounded-xl p-5 shadow-sm border border-[#d1f4da]">
                    <div class="text-green-600 text-lg font-bold mb-1">₹8 LPA</div>
                    <div class="text-gray-600 text-sm font-medium">Annual CTC</div>
                </div>
                <div class="bg-[#eff6ff] rounded-xl p-5 shadow-sm border border-[#dbeafe]">
                    <div class="text-blue-700 text-lg font-bold mb-1">₹25,000/month</div>
                    <div class="text-gray-600 text-sm font-medium">Stipend</div>
                </div>
                <div class="bg-[#fefce8] rounded-xl p-5 shadow-sm border border-[#fef08a]">
                    <div class="text-yellow-700 text-lg font-bold mb-1">6 Months</div>
                    <div class="text-gray-600 text-sm font-medium">Internship</div>
                </div>
                <div class="bg-[#fef2f2] rounded-xl p-5 shadow-sm border border-[#fecaca]">
                    <div class="text-red-700 text-lg font-bold mb-1">1 Year</div>
                    <div class="text-gray-600 text-sm font-medium">Bond</div>
                </div>
            </div>

            <!-- Description Content -->
            <div class="bg-[#ece6da] p-6 rounded-lg border border-[#e0dacd] shadow-sm">
                <div class="mb-6">
                    <h3 class="text-lg font-bold text-gray-900 mb-3 border-b border-gray-300 pb-2 m-0">About Company &amp; Job Description</h3>
                    <p class="text-sm text-gray-700 leading-relaxed whitespace-pre-wrap m-0">We are looking for a talented Software Development Engineer to join our dynamic team. You will be responsible for developing and maintaining high-quality software applications, working with cutting-edge technologies, and contributing to innovative projects that impact millions of users.</p>
                </div>

                <div class="mb-6">
                    <h3 class="text-lg font-bold text-gray-900 mb-3 border-b border-gray-300 pb-2 m-0">Selection Process</h3>
                    <p class="text-sm text-gray-700 leading-relaxed whitespace-pre-wrap m-0">1. Online Aptitude Test
2. Technical Interview
3. HR Interview</p>
                </div>

                <div>
                    <h3 class="text-lg font-bold text-gray-900 mb-3 border-b border-gray-300 pb-2 m-0">Additional Information</h3>
                    <p class="text-sm text-gray-700 leading-relaxed whitespace-pre-wrap m-0">Looking for immediate joiners with good problem-solving skills.</p>
                </div>
            </div>
        </div>

        <!-- Right Section -->
        <div class="lg:col-span-1 space-y-6">

            <div class="bg-[#ece6da] p-6 rounded-lg border border-[#e0dacd] shadow-sm">
                <h3 class="text-lg font-bold text-gray-900 mb-4 m-0">Eligibility &amp; Dates</h3>

                <div class="space-y-4">
                    <div>
                        <div class="text-sm font-bold text-gray-900">Eligible Courses</div>
                        <div class="text-sm text-gray-600">B.Tech CSE, B.Tech IT, MCA</div>
                    </div>
                    <div>
                        <div class="text-sm font-bold text-gray-900">Eligible Batches</div>
                        <div class="text-sm text-gray-600">2026</div>
                    </div>
                    <div>
                        <div class="text-sm font-bold text-gray-900">Drive Date</div>
                        <div class="text-sm text-gray-600">Jan 15, 2026</div>
                    </div>
                    <div>
                        <div class="text-sm font-bold text-gray-900">Tentative Joining Date</div>
                        <div class="text-sm text-gray-600">July 2026</div>
                    </div>
                </div>
            </div>

            <div class="pt-2 flex flex-col items-center">
                <button class="w-full py-4 rounded-xl font-bold text-white uppercase bg-[#e7000b] hover:bg-red-700 transition-colors shadow-md flex items-center justify-center gap-2 mb-3 border-none cursor-pointer">
                    APPLY NOW <span class="text-xl leading-none">→</span>
                </button>
            </div>

        </div>
    </div>
</div>
