@{ ViewData["Title"] = "Forgot Password"; }

<div class="w-full">
    <header class="page-header flex justify-between items-start mb-8">
        <div>
            <h1 class="page-title">Forgot Password</h1>
            <p class="page-subtitle">Update your password to recover your account.</p>
        </div>
    </header>

    <div class="flex justify-center">
        <form onsubmit="return validateForgotPassword(event)" class="bg-[#ece6da] border-[1.5px] border-[#e7000b] p-6 md:p-8 rounded-xl shadow-sm w-full max-w-lg">
            <!-- Email -->
            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-800 mb-2">Registered Email Address</label>
                <div class="relative">
                    <input type="email" id="forgotEmail" name="email" class="w-full p-3 pl-10 bg-white rounded-lg border border-[#e0d8cc] outline-none text-gray-800 focus:border-[#e7000b]" placeholder="Enter your college email" oninput="validateFieldRealtime('email')" />
                    <i class="fas fa-envelope absolute left-3 top-1/2 -translate-y-1/2 text-gray-500"></i>
                </div>
                <p id="emailError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- New Password -->
            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-800 mb-2">New Password</label>
                <div class="relative">
                    <input type="password" id="newPassword" name="newPassword" class="w-full p-3 bg-white rounded-lg border border-[#e0d8cc] outline-none text-gray-800 focus:border-[#e7000b]" placeholder="Enter new password" oninput="validateFieldRealtime('new')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'newPassword')">Show</button>
                </div>
                <p id="newError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Confirm Password -->
            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-800 mb-2">Confirm Password</label>
                <div class="relative">
                    <input type="password" id="confirmPassword" name="confirmPassword" class="w-full p-3 bg-white rounded-lg border border-[#e0d8cc] outline-none text-gray-800 focus:border-[#e7000b]" placeholder="Re-enter new password" oninput="validateFieldRealtime('confirm')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'confirmPassword')">Show</button>
                </div>
                <p id="confirmError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Password Requirements -->
            <div class="bg-white border border-[#e0d8cc] p-4 rounded-lg mb-5 text-sm">
                <p class="font-bold text-gray-800 mb-2">Password requirements:</p>
                <ul class="space-y-1 text-gray-500 list-none p-0">
                    <li>✔ At least 8 characters long</li>
                    <li>✔ Contains uppercase and lowercase letters</li>
                    <li>✔ Contains at least one number</li>
                    <li>✔ Contains at least one special character</li>
                </ul>
            </div>

            <!-- Update Button -->
            <button type="submit" class="w-full bg-[#e7000b] text-white py-3 rounded-lg mb-3 font-bold uppercase transition-all hover:bg-red-700 border-none cursor-pointer">Update Password</button>

            <!-- Cancel Button -->
            <button type="button" onclick="history.back()" class="w-full bg-transparent border border-gray-400 text-gray-800 py-3 rounded-lg font-bold uppercase transition-all hover:bg-gray-100 cursor-pointer">Cancel</button>
        </form>
    </div>
</div>
