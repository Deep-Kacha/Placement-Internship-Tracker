@{ ViewData["Title"] = "Interview Schedule Form"; }

<div class="w-full">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4 md:gap-0 relative z-10">
        <div>
            <h1 class="text-2xl md:text-3xl font-bold text-red-600">Interview Schedule Form</h1>
            <p class="text-gray-600 text-sm md:text-base">Manage interview Rounds.</p>
        </div>
        <div class="flex gap-3 w-full md:w-auto">
            <button type="button" onclick="history.back()" class="border px-5 py-2 rounded-lg w-full md:w-auto bg-white cursor-pointer hover:bg-gray-50 text-gray-800">
                ← Back
            </button>
        </div>
    </div>

    <!-- Company Details Card -->
    <div class="bg-[#d8cfc3] p-6 md:p-8 rounded-xl shadow-md mb-6">
        <h2 class="text-lg font-semibold mb-6 m-0">Company Details</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm mb-1">Company Name</label>
                <input type="text" value="Multiicon" class="w-full p-3 rounded-lg border outline-none bg-white" />
            </div>
            <div>
                <label class="block text-sm mb-1">HR Name</label>
                <input type="text" value="Shweta Jethwa" class="w-full p-3 rounded-lg border outline-none bg-white" />
            </div>
        </div>
    </div>

    <!-- Rounds Cards Container -->
    <div id="roundsContainer">
        <!-- Initial Round Card -->
        <div class="round-card bg-[#d8cfc3] p-6 md:p-8 rounded-xl shadow-md mb-6 relative">
            <div class="flex justify-between items-center mb-6">
                <h2 class="round-title text-lg font-semibold m-0">Round 1 Details</h2>
                <button type="button" onclick="deleteRound(this)" class="delete-round-btn text-red-600 hover:text-red-800 p-2 rounded-full hover:bg-red-100 transition-colors hidden cursor-pointer border-none bg-transparent" title="Delete Round">
                    <i class="fas fa-trash-alt text-lg"></i>
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm mb-1">Round No</label>
                    <input type="text" placeholder="e.g. 1" class="w-full p-3 rounded-lg border outline-none bg-white" />
                </div>
                <div>
                    <label class="block text-sm mb-1">Round Name</label>
                    <input type="text" placeholder="e.g. Aptitude Test" class="w-full p-3 rounded-lg border outline-none bg-white" />
                </div>
                <div>
                    <label class="block text-sm mb-1">Venue</label>
                    <input type="text" value="Panel No. 2" class="w-full p-3 rounded-lg border outline-none bg-white" />
                </div>
                <div>
                    <label class="block text-sm mb-1">Waiting Area</label>
                    <input type="text" value="Krishna Murti hall" class="w-full p-3 rounded-lg border outline-none bg-white" />
                </div>
                <div>
                    <label class="block text-sm mb-1">Date</label>
                    <input type="date" value="2025-05-15" class="w-full p-3 rounded-lg border outline-none bg-white" />
                </div>
                <div>
                    <label class="block text-sm mb-1">Timing</label>
                    <input type="time" value="08:00" class="w-full p-3 rounded-lg border outline-none bg-white" />
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mt-8 pb-8">
        <button type="button" onclick="addRound()" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 w-full md:w-auto cursor-pointer border-none transition font-semibold text-base">
            Schedule Another Round
        </button>
        <button type="button" onclick="submitInterviewSchedule()" class="bg-red-600 text-white px-6 py-3 rounded-lg hover:bg-red-700 w-full md:w-auto cursor-pointer border-none transition font-semibold text-base">
            Submit
        </button>
    </div>
</div>

<script>
    function updateRoundNumbers() {
        const cards = document.querySelectorAll('.round-card');
        const deleteBtns = document.querySelectorAll('.delete-round-btn');
        
        cards.forEach((card, index) => {
            card.querySelector('.round-title').innerText = `Round ${index + 1} Details`;
        });

        // Hide delete button if only 1 round left
        if (cards.length > 1) {
            deleteBtns.forEach(btn => btn.classList.remove('hidden'));
        } else {
            deleteBtns.forEach(btn => btn.classList.add('hidden'));
        }
    }

    function addRound() {
        const container = document.getElementById('roundsContainer');
        const template = container.querySelector('.round-card').cloneNode(true);
        
        // Clear inputs on cloned default round
        template.querySelectorAll('input').forEach(input => input.value = '');
        
        container.appendChild(template);
        updateRoundNumbers();
    }

    function deleteRound(btn) {
        const card = btn.closest('.round-card');
        card.remove();
        updateRoundNumbers();
    }

    function submitInterviewSchedule() {
        alert('Interview Schedule submitted successfully!');
        window.location.href = '/AdminInterviewSchedule';
    }
</script>
