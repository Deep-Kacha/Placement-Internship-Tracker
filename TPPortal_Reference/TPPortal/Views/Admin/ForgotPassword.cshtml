@{ ViewData["Title"] = "Forgot Password"; }

<div class="w-full">
    <h1 class="text-2xl md:text-3xl font-bold text-red-600">Forgot Password</h1>
    <p class="text-gray-600 mb-6 md:mb-8 text-sm md:text-base">Update your password to recover your account.</p>

    <div class="flex justify-center">
        <form onsubmit="return validateForgotPassword(event)" class="bg-[#d8cfc3] p-6 md:p-8 rounded-xl shadow-md w-full max-w-md">
            <!-- Email -->
            <div class="mb-5">
                <label class="block text-sm mb-1">Registered Email Address</label>
                <div class="relative">
                    <input type="email" id="forgotEmail" name="email" placeholder="Enter your college email" class="w-full p-3 rounded-lg border outline-none pl-10" oninput="validateFieldRealtime('email')" />
                    <i class="fas fa-envelope absolute left-3 top-1/2 -translate-y-1/2 text-gray-500"></i>
                </div>
                <p id="emailError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- New Password -->
            <div class="mb-5">
                <label class="block text-sm mb-1">New Password</label>
                <div class="relative">
                    <input type="password" id="newPassword" name="newPassword" placeholder="Enter new password" class="w-full p-3 rounded-lg border outline-none" oninput="validateFieldRealtime('new')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'newPassword')">Show</button>
                </div>
                <p id="newError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Confirm Password -->
            <div class="mb-5">
                <label class="block text-sm mb-1">Confirm Password</label>
                <div class="relative">
                    <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Re-enter new password" class="w-full p-3 rounded-lg border outline-none" oninput="validateFieldRealtime('confirm')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'confirmPassword')">Show</button>
                </div>
                <p id="confirmError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Password Rules -->
            <div class="bg-gray-100 p-4 rounded-lg mb-5 text-sm">
                <p class="font-semibold mb-2">Password must contain:</p>
                <ul class="space-y-1 text-gray-600 list-none p-0">
                    <li>✔ At least 8 characters</li>
                    <li>✔ One uppercase letter</li>
                    <li>✔ One lowercase letter</li>
                    <li>✔ One number</li>
                </ul>
            </div>

            <!-- Confirm Button -->
            <button type="submit" class="w-full bg-red-600 text-white py-3 rounded-lg mb-3 hover:bg-red-700 border-none cursor-pointer">Confirm Password</button>

            <!-- Cancel Button -->
            <button type="button" onclick="history.back()" class="w-full border py-3 rounded-lg hover:bg-gray-50 cursor-pointer bg-transparent">Cancel</button>
        </form>
    </div>
</div>
