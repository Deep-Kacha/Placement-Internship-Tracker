@{
    ViewData["Title"] = "Login";
}

<div class="min-h-screen flex flex-col bg-gray-200">
    <div class="flex-grow flex flex-col items-center justify-center px-4 py-12">
        <!-- Title -->
        <div class="text-center mb-8">
            <h1 class="text-2xl md:text-3xl font-bold">RK University <br /> Training &amp; Placement Cell</h1>
        </div>

        <!-- Login Card -->
        <form onsubmit="return validateLogin(event)" class="bg-[#d8cfc2] p-8 rounded-xl shadow-lg w-full max-w-md">
            <h2 class="text-xl font-bold text-center mb-2">Welcome Back</h2>
            <p class="text-center text-sm text-gray-600 mb-6">Sign in to access your account</p>

            <!-- Select Role -->
            <div class="mb-4">
                <label class="text-sm font-medium">Select Role</label>
                <select id="loginRole" class="w-full mt-1 p-2 rounded-md border" onchange="validateFieldRealtime('role')">
                    <option value="">Choose your role</option>
                    <option value="Student">Student</option>
                    <option value="Admin">Admin</option>
                </select>
                <p id="roleError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Email -->
            <div class="mb-4">
                <label class="text-sm font-medium">Email Address</label>
                <input type="email" id="loginEmail" placeholder="Enter your college email" class="w-full mt-1 p-2 rounded-md border" oninput="validateFieldRealtime('loginEmail')" />
                <p id="emailError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Password -->
            <div class="mb-2">
                <label class="text-sm font-medium">Password</label>
                <div class="relative mt-1">
                    <input type="password" id="loginPassword" placeholder="Enter your password" class="w-full p-2 rounded-md border" oninput="validateFieldRealtime('loginPassword')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500" onclick="togglePassword('loginPassword', 'loginPwdIcon')">
                        <i id="loginPwdIcon" class="fas fa-eye"></i>
                    </button>
                </div>
                <p id="passwordError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <p id="loginError" class="text-red-500 text-sm mb-4 hidden"></p>

            <div class="text-right text-sm mb-4">
                <a href="/ForgotPassword" class="hover:underline cursor-pointer text-gray-700 no-underline">Forgot Password?</a>
            </div>

            <!-- Login Button -->
            <button type="submit" class="w-full bg-red-600 text-white py-2 rounded-md hover:bg-red-700 transition mb-3 border-none cursor-pointer font-medium">Login</button>
            <button type="button" onclick="history.back()" class="w-full border border-black py-2 rounded-md hover:bg-gray-100 transition cursor-pointer bg-transparent font-medium">Cancel</button>

            <div class="text-center mt-6 text-sm">
                <p>Don't have an account? <a href="/Register" class="font-semibold cursor-pointer hover:underline text-gray-900">Register ?</a></p>
            </div>
        </form>
    </div>
</div>
