@model PlacementTracker.ViewModels.ResetPasswordViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>Set New Password — Trackeoo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: { 50: '#fef2f2', 100: '#fee2e2', 500: '#ef4444', 600: '#dc2626', 700: '#B91C1C', 800: '#991b1b', 900: '#7F1D1D' },
                        cream: { 50: '#FFFBF5', 100: '#FFF7ED' }
                    },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style> body { font-family: 'Inter', sans-serif; background-color: #FFFBF5; } </style>
</head>
<body class="min-h-screen flex items-center justify-center bg-cream-50 p-6 selection:bg-brand-200 selection:text-brand-900">

<div class="w-full max-w-md bg-white rounded-3xl shadow-2xl overflow-hidden border border-cream-200">
    <!-- Header -->
    <div class="bg-gradient-to-br from-brand-900 to-brand-700 p-8 text-center text-white relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10 mix-blend-overlay"></div>
        <div class="relative z-10 flex flex-col items-center">
            <div class="w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center backdrop-blur-md border border-white/20 mb-4">
                <i class="bi bi-shield-lock-fill text-3xl text-white"></i>
            </div>
            <h4 class="text-2xl font-extrabold tracking-tight mb-1">Set New Password</h4>
            <p class="text-brand-100/80 text-xs font-semibold tracking-wider uppercase">Secure your account</p>
        </div>
    </div>

    <!-- Form -->
    <div class="p-8">
        <form asp-action="ResetPassword" method="post" class="space-y-5">
            <div asp-validation-summary="All" class="text-brand-600 text-sm font-medium"></div>
            
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <div>
                <label asp-for="Password" class="block text-sm font-semibold text-gray-700 mb-1.5"><i class="bi bi-key fill-current mr-1"></i> New Password</label>
                <div class="relative">
                    <input asp-for="Password" id="resetPassword" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 transition-all outline-none bg-gray-50 focus:bg-white pr-12" placeholder="Min 6 characters" type="password"/>
                    <button type="button" onclick="togglePassword('resetPassword', 'eyeIconReset1')" class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-brand-600 transition-colors">
                        <i id="eyeIconReset1" class="bi bi-eye-fill fs-5"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-brand-600 text-xs mt-1"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-semibold text-gray-700 mb-1.5"><i class="bi bi-check-all fill-current mr-1"></i> Confirm Password</label>
                <div class="relative">
                    <input asp-for="ConfirmPassword" id="resetConfirmPassword" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 transition-all outline-none bg-gray-50 focus:bg-white pr-12" placeholder="Re-enter password" type="password"/>
                    <button type="button" onclick="togglePassword('resetConfirmPassword', 'eyeIconReset2')" class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-brand-600 transition-colors">
                        <i id="eyeIconReset2" class="bi bi-eye-fill fs-5"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-brand-600 text-xs mt-1"></span>
            </div>

            <button type="submit" class="w-full py-3.5 bg-brand-700 hover:bg-brand-800 text-white font-bold rounded-xl transition-all shadow-lg shadow-brand-700/30 flex items-center justify-center gap-2 mt-4">
                Update Password <i class="bi bi-check-circle-fill"></i>
            </button>
        </form>
    </div>
</div>

<script>
    function togglePassword(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('bi-eye-fill');
            icon.classList.add('bi-eye-slash-fill');
        } else {
            input.type = 'password';
            icon.classList.remove('bi-eye-slash-fill');
            icon.classList.add('bi-eye-fill');
        }
    }
</script>
</body>
</html>
