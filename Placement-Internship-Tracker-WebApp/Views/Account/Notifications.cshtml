@model List<PlacementTracker.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    var unreadCount = Model.Count(n => !n.IsRead);
}

<div class="container-fluid px-0">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white p-4 d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0 fw-bold">Notifications</h5>
                <p class="text-muted small mb-0 mt-1">Stay updated with the latest activity on your portal.</p>
            </div>
            @if (unreadCount > 0)
            {
                <button class="btn btn-sm btn-light border" onclick="markAllAsRead()">Mark all as read</button>
            }
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="p-5 text-center">
                    <div class="w-16 h-16 bg-gray-50 rounded-circle flex items-center justify-center mx-auto mb-4">
                        <i class="bi bi-bell-slash text-gray-300 h3 mb-0"></i>
                    </div>
                    <h6 class="fw-bold">No notifications yet</h6>
                    <p class="text-muted small">We'll alert you when there's something new.</p>
                </div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var n in Model)
                    {
                        <div class="list-group-item p-4 @(n.IsRead ? "bg-white opacity-75" : "bg-brand-50/30 border-start border-brand-500 border-4") transition-all">
                            <div class="d-flex gap-4">
                                <div class="flex-shrink-0">
                                    <div class="w-12 h-12 rounded-xl @(n.IsRead ? "bg-gray-100 text-gray-400" : "bg-brand-100 text-brand-700") flex items-center justify-center">
                                        <i class="bi bi-info-circle-fill h5 mb-0"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between mb-1">
                                        <h6 class="mb-0 fw-bold">System Update</h6>
                                        <span class="text-muted small">@n.CreatedAt.ToString("MMM dd, h:mm tt")</span>
                                    </div>
                                    <p class="text-dark small mb-3">@n.Message</p>
                                    <div class="d-flex gap-2">
                                        @if (!string.IsNullOrEmpty(n.Link))
                                        {
                                            <a href="@n.Link" class="btn btn-sm btn-brand-700 text-white px-3 fw-bold decoration-none" style="background-color: #B91C1C;">View Details</a>
                                        }
                                        @if (!n.IsRead)
                                        {
                                            <button onclick="markAsRead(@n.Id, this)" class="btn btn-sm btn-light border px-3 fw-bold">Mark as read</button>
                                        }
                                        <form asp-action="DeleteNotification" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@n.Id" />
                                            <button type="submit" class="btn btn-sm btn-white text-danger border p-1 px-2"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function markAsRead(id, btn) {
        const response = await fetch('/Account/MarkNotificationRead/' + id, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        if (response.ok) {
            const item = btn.closest('.list-group-item');
            item.classList.add('bg-white', 'opacity-75');
            item.classList.remove('bg-brand-50/30', 'border-start', 'border-brand-500', 'border-4');
            btn.remove();
        }
    }
</script>
}
