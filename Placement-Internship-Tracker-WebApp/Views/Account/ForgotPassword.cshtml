@model PlacementTracker.ViewModels.ForgotPasswordViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>Forgot Password — Trackeoo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: { 50: '#fef2f2', 100: '#fee2e2', 500: '#ef4444', 600: '#dc2626', 700: '#B91C1C', 800: '#991b1b', 900: '#7F1D1D' },
                        cream: { 50: '#FFFBF5', 100: '#FFF7ED' }
                    },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style> body { font-family: 'Inter', sans-serif; background-color: #FFFBF5; } </style>
</head>
<body class="min-h-screen flex items-center justify-center bg-cream-50 p-6 selection:bg-brand-200 selection:text-brand-900">

<div class="w-full max-w-md bg-white rounded-3xl shadow-2xl overflow-hidden border border-cream-200">
    <!-- Header -->
    <div class="bg-gradient-to-br from-brand-900 to-brand-700 p-8 text-center text-white relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10 mix-blend-overlay"></div>
        <div class="relative z-10 flex flex-col items-center">
            <div class="w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center backdrop-blur-md border border-white/20 mb-4">
                <i class="bi bi-shield-lock-fill text-3xl text-white"></i>
            </div>
            <h4 class="text-2xl font-extrabold tracking-tight mb-1">Forgot Password</h4>
            <p class="text-brand-100/80 text-xs font-semibold tracking-wider uppercase">Reset your account access</p>
        </div>
    </div>

    <!-- Form -->
    <div class="p-8">
        <p class="text-gray-500 text-sm mb-6 text-center leading-relaxed">
            Enter the email address associated with your account and we'll generate a password reset link for you.
        </p>

        <form asp-action="ForgotPassword" method="post" class="space-y-5">
            <div asp-validation-summary="All" class="text-brand-600 text-sm font-medium"></div>

            <div>
                <label asp-for="Email" class="block text-sm font-semibold text-gray-700 mb-1.5"><i class="bi bi-envelope fill-current mr-1"></i> Email Address</label>
                <input asp-for="Email" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 transition-all outline-none bg-gray-50 focus:bg-white" placeholder="you@example.com" autofocus/>
                <span asp-validation-for="Email" class="text-brand-600 text-xs mt-1"></span>
            </div>

            <button type="submit" class="w-full py-3.5 bg-brand-700 hover:bg-brand-800 text-white font-bold rounded-xl transition-all shadow-lg shadow-brand-700/30 flex items-center justify-center gap-2">
                Send Reset Link <i class="bi bi-arrow-right"></i>
            </button>
        </form>

        <div class="mt-8 pt-6 border-t border-gray-100 text-center">
            <p class="text-gray-600 text-sm"><a asp-action="Login" class="text-brand-600 font-bold hover:text-brand-800 transition-colors"><i class="bi bi-arrow-left"></i> Back to Login</a></p>
        </div>
    </div>
</div>

</body>
</html>
