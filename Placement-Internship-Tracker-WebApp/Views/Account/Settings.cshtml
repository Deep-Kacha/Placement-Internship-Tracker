@model PlacementTracker.ViewModels.SettingsViewModel
@{
    ViewData["Title"] = "Account Settings";
}

<div class="container-fluid px-0">
    <div class="row">
        <!-- Settings Sidebar -->
        <div class="col-lg-3">
            <div class="card shadow-sm border-0 overflow-hidden mb-4">
                <div class="list-group list-group-flush">
                    <a href="#" class="list-group-item list-group-item-action active bg-brand-700 border-brand-700 py-3">
                        <i class="bi bi-shield-lock me-2"></i> Password & Security
                    </a>
                    <a href="#" class="list-group-item list-group-item-action py-3">
                        <i class="bi bi-bell me-2"></i> Notification Preferences
                    </a>
                    <a href="#" class="list-group-item list-group-item-action py-3">
                        <i class="bi bi-envelope me-2"></i> Linked Accounts
                    </a>
                </div>
            </div>
        </div>

        <!-- Content Area -->
        <div class="col-lg-9">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white p-4">
                    <h5 class="mb-0 fw-bold">Change Password</h5>
                    <p class="text-muted small mb-0 mt-1">Ensure your account is using a long, random password to stay secure.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-4 small"></div>
                        
                        <div class="row g-4 max-w-lg">
                            <div class="col-12">
                                <label asp-for="CurrentPassword" class="form-label"></label>
                                <input asp-for="CurrentPassword" class="form-control" type="password" placeholder="••••••••" />
                                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                            </div>
                            
                            <div class="col-12">
                                <label asp-for="NewPassword" class="form-label"></label>
                                <input asp-for="NewPassword" class="form-control" type="password" placeholder="••••••••" />
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="ConfirmPassword" class="form-label"></label>
                                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••••" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-5 pt-3 border-top d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">Update Password</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Notification Settings -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white p-4">
                    <h5 class="mb-0 fw-bold">Notification Preferences</h5>
                </div>
                <div class="card-body p-4">
                    <div class="space-y-4">
                        <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded-xl mb-3">
                            <div>
                                <h6 class="mb-0 fw-bold">Email Notifications</h6>
                                <p class="text-muted small mb-0">Receive placement updates on your registered email.</p>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input h5 mb-0" type="checkbox" checked>
                            </div>
                        </div>
                        <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded-xl mb-3">
                            <div>
                                <h6 class="mb-0 fw-bold">Push Notifications</h6>
                                <p class="text-muted small mb-0">Get real-time browser alerts for interview schedules.</p>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input h5 mb-0" type="checkbox" checked>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
