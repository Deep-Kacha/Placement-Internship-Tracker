@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>Password Reset Successful — Trackeoo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: { 50: '#fef2f2', 100: '#fee2e2', 500: '#ef4444', 600: '#dc2626', 700: '#B91C1C', 800: '#991b1b', 900: '#7F1D1D' },
                        cream: { 50: '#FFFBF5', 100: '#FFF7ED' }
                    },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style> body { font-family: 'Inter', sans-serif; background-color: #FFFBF5; } </style>
</head>
<body class="min-h-screen flex items-center justify-center bg-cream-50 p-6 selection:bg-brand-200 selection:text-brand-900">

<div class="w-full max-w-md bg-white rounded-3xl shadow-2xl overflow-hidden border border-cream-200">
    <!-- Header -->
    <div class="bg-gradient-to-br from-brand-900 to-brand-700 p-8 text-center text-white relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10 mix-blend-overlay"></div>
        <div class="relative z-10 flex flex-col items-center">
            <div class="w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center backdrop-blur-md border border-white/20 mb-4 text-green-300">
                <i class="bi bi-patch-check-fill text-4xl"></i>
            </div>
            <h4 class="text-2xl font-extrabold tracking-tight mb-1">Reset Successful</h4>
            <p class="text-brand-100/80 text-xs font-semibold tracking-wider uppercase">Your password has been changed</p>
        </div>
    </div>

    <!-- Content -->
    <div class="p-8 text-center">
        <p class="text-gray-600 mb-8 leading-relaxed">
            You can now use your new password to log in to your Trackeoo account.
        </p>

        <a asp-action="Login" class="w-full inline-flex items-center justify-center py-3.5 bg-brand-700 hover:bg-brand-800 text-white font-bold rounded-xl transition-all shadow-lg shadow-brand-700/30 gap-2">
            Go to Login <i class="bi bi-box-arrow-in-right text-lg"></i>
        </a>
    </div>
</div>

</body>
</html>
