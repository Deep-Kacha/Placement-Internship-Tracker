@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>Email Sent — Trackeoo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: { 50: '#fef2f2', 100: '#fee2e2', 500: '#ef4444', 600: '#dc2626', 700: '#B91C1C', 800: '#991b1b', 900: '#7F1D1D' },
                        cream: { 50: '#FFFBF5', 100: '#FFF7ED' }
                    },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style> body { font-family: 'Inter', sans-serif; background-color: #FFFBF5; } </style>
</head>
<body class="min-h-screen flex items-center justify-center bg-cream-50 p-6 selection:bg-brand-200 selection:text-brand-900">

<div class="w-full max-w-md bg-white rounded-3xl shadow-2xl overflow-hidden border border-cream-200">
    <!-- Header -->
    <div class="bg-gradient-to-br from-brand-900 to-brand-700 p-8 text-center text-white relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10 mix-blend-overlay"></div>
        <div class="relative z-10 flex flex-col items-center">
            <div class="w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center backdrop-blur-md border border-white/20 mb-4 text-green-400">
                <i class="bi bi-envelope-check-fill text-3xl"></i>
            </div>
            <h4 class="text-2xl font-extrabold tracking-tight mb-1">Check Your Email</h4>
            <p class="text-brand-100/80 text-xs font-semibold tracking-wider uppercase">Reset Link Sent</p>
        </div>
    </div>

    <!-- Content -->
    <div class="p-8 text-center">
        <p class="text-gray-600 mb-6 leading-relaxed">
            If an account matching that email address exists, we've sent instructions on how to reset your password. 
            <br/><br/>
            <span class="text-sm"><b>Note for this demo:</b> Check the simulated reset link block below.</span>
        </p>

        @if (TempData["ResetLink"] != null)
        {
            <div class="mb-6 p-4 bg-yellow-50 border border-yellow-200 rounded-xl text-left overflow-hidden">
                <p class="text-xs font-bold text-yellow-800 uppercase tracking-wider mb-2">Simulated Email Inbox</p>
                <p class="text-sm text-yellow-900 mb-3">Click the link below to verify your token and reset your password:</p>
                <a href="@TempData["ResetLink"]" class="inline-block break-all text-xs text-brand-600 hover:text-brand-800 font-mono underline decoration-brand-300 underline-offset-2">@TempData["ResetLink"]</a>
            </div>
        }

        <div class="pt-6 border-t border-gray-100">
            <a asp-action="Login" class="w-full py-3.5 bg-gray-900 hover:bg-black text-white font-bold rounded-xl transition-all shadow-lg shadow-gray-900/20 flex items-center justify-center gap-2">
                Return to Login <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</div>

</body>
</html>
