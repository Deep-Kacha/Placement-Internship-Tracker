@model IEnumerable<PlacementTracker.Models.JobDescription>
@{ ViewData["Title"] = "Manage Job Postings"; }

<h4 class="fw-bold mb-4">Manage Job Postings</h4>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Job Title</th>
                        <th>Company</th>
                        <th>Recruiter</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(!Model.Any()) {
                        <tr><td colspan="6" class="text-center py-5 text-muted">No jobs posted yet.</td></tr>
                    }
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4 fw-semibold text-dark">@item.Title</td>
                            <td>@item.CompanyName</td>
                            <td>@(item.Recruiter?.FullName ?? "Unknown")</td>
                            <td>@item.JobType</td>
                            <td>
                                @if(item.Status == "Approved") { <span class="badge bg-success">Approved</span> }
                                else if(item.Status == "Rejected") { <span class="badge bg-danger">Rejected</span> }
                                else { <span class="badge bg-warning text-dark">Pending</span> }
                            </td>
                            <td class="text-end pe-4">
                                <form asp-action="UpdateJDStatus" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    @if(item.Status != "Approved") {
                                        <button type="submit" name="status" value="Approved" class="btn btn-sm btn-success me-1">Approve</button>
                                    }
                                    @if(item.Status != "Rejected") {
                                        <button type="submit" name="status" value="Rejected" class="btn btn-sm btn-outline-danger me-1">Reject</button>
                                    }
                                </form>
                                <a asp-action="JobDescriptionDetails" asp-route-id="@item.Id" class="btn btn-sm btn-light border">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
