@model IEnumerable<PlacementTracker.Models.JobDescription>
@{ ViewData["Title"] = "Manage Job Postings"; }

<h4 class="fw-bold mb-4">Manage Job Postings</h4>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Job Title</th>
                        <th>Company</th>
                        <th>Recruiter</th>
                        <th>CTC / Stipend</th>
                        <th>Deadline</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(!Model.Any()) {
                        <tr><td colspan="6" class="text-center py-5 text-muted">No jobs posted yet.</td></tr>
                    }
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.Title</div>
                                <div class="text-muted small">@item.JobType</div>
                            </td>
                            <td>@item.CompanyName</td>
                            <td>
                                @if (item.Recruiter != null) {
                                    <div class="fw-medium">@item.Recruiter.FullName</div>
                                    <div class="text-muted x-small">Registered</div>
                                } else {
                                    <div class="text-brand-600 fw-bold">Guest</div>
                                    <div class="text-muted x-small">@item.ContactEmail</div>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.AnnualCTC)) { <span class="d-block small">CTC: @item.AnnualCTC</span> }
                                @if (!string.IsNullOrEmpty(item.Stipend)) { <span class="d-block small">Stipend: @item.Stipend</span> }
                                @if (string.IsNullOrEmpty(item.AnnualCTC) && string.IsNullOrEmpty(item.Stipend)) { <span class="text-muted">-</span> }
                            </td>
                            <td class="small">@item.Deadline.ToString("dd MMM yyyy")</td>
                            <td>
                                @if(item.Status == "Approved") { <span class="badge bg-success">Approved</span> }
                                else if(item.Status == "Rejected") { <span class="badge bg-danger">Rejected</span> }
                                else { <span class="badge bg-warning text-dark border border-warning">Pending</span> }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="JobDescriptionDetails" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Review</a>
                                    
                                    <form asp-action="UpdateJDStatus" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        @if(item.Status == "Pending") {
                                            <button type="submit" name="status" value="Approved" class="btn btn-sm btn-outline-success" title="Approve"><i class="bi bi-check-lg"></i></button>
                                            <button type="submit" name="status" value="Rejected" class="btn btn-sm btn-outline-danger" title="Reject"><i class="bi bi-x-lg"></i></button>
                                        }
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
