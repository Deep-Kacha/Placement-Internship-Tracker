@using PlacementTracker.Models
@{ ViewData["Title"] = "Manage Users";
    var students = ViewBag.Students as List<ApplicationUser> ?? new();
    var faculty = ViewBag.Faculty as List<ApplicationUser> ?? new();
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-person-plus me-2"></i>Manage Users</h5>
    <div class="d-flex gap-2">
        <a asp-action="CreateStudent" class="btn btn-primary btn-sm"><i class="bi bi-plus me-1"></i>Add Student</a>
        <a asp-action="CreateFaculty" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus me-1"></i>Add Faculty</a>
    </div>
</div>

<div class="row g-4">
<div class="col-md-7">
    <div class="card border-0 shadow-sm"><div class="card-body">
    <h6 class="fw-semibold mb-3">Students (@students.Count)</h6>
    <div class="table-responsive"><table class="table table-sm table-hover mb-0">
        <thead class="table-light"><tr><th>Name</th><th>Branch/Sem</th><th>CGPA</th><th>Approved</th><th>Active</th><th class="text-end">Actions</th></tr></thead>
        <tbody>@foreach (var s in students){
        <tr class="align-middle @(!s.IsActive?"table-danger":"") @(!s.IsApproved?"table-warning":"")">
            <td class="fw-semibold">@s.FullName<br/><small class="text-muted fw-normal">@s.Email</small></td>
            <td class="small text-muted">@(s.Branch ?? "-") / @(s.Semester ?? "-")</td>
            <td class="small fw-medium">@(s.CGPA?.ToString("0.00") ?? "-")</td>
            <td>@if(s.IsApproved){<span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 shadow-sm">Yes</span>}else{<span class="badge bg-warning bg-opacity-10 text-dark border border-warning shadow-sm">Pending</span>}</td>
            <td>@if(s.IsActive){<span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 shadow-sm">Yes</span>}else{<span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 shadow-sm">No</span>}</td>
            <td class="text-end">
                <div class="d-flex justify-content-end align-items-center gap-2">
                    @if(!s.IsApproved){
                        <form asp-action="ApproveStudent" method="post" class="m-0">@Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@s.Id"/>
                            <button class="btn btn-sm btn-success fw-semibold shadow-sm d-flex align-items-center gap-1"><i class="bi bi-check-circle"></i> Approve</button>
                        </form>
                    }
                    <form asp-action="ToggleUser" method="post" class="m-0">@Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@s.Id"/>
                        <button class="btn btn-sm btn-outline-secondary fw-semibold shadow-sm text-nowrap">Toggle</button>
                    </form>
                </div>
            </td>
        </tr>}</tbody>
    </table></div></div></div>
</div>
<div class="col-md-5">
    <div class="card border-0 shadow-sm mb-3"><div class="card-body">
    <h6 class="fw-semibold mb-3">Faculty (@faculty.Count)</h6>
    <ul class="list-group list-group-flush">
    @foreach (var f in faculty){
    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
        <div><span class="fw-semibold">@f.FullName</span><br/><small class="text-muted fw-normal">@f.Email &middot; @f.Department</small></div>
        <form asp-action="ToggleUser" method="post" class="m-0">@Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@f.Id"/>
            <button class="btn btn-sm btn-outline-secondary fw-semibold shadow-sm text-nowrap">Toggle</button>
        </form>
    </li>}
    </ul></div></div>

    <div class="card border-0 shadow-sm"><div class="card-body">
    <h6 class="fw-semibold mb-3">Assign Student → Faculty</h6>
    <form asp-action="AssignStudentToFaculty" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-2"><select name="facultyId" class="form-select form-select-sm" required>
            <option value="">Select Faculty</option>
            @foreach (var f in faculty){ <option value="@f.Id">@f.FullName</option> }
        </select></div>
        <div class="mb-2"><select name="studentId" class="form-select form-select-sm" required>
            <option value="">Select Student</option>
            @foreach (var s in students){ <option value="@s.Id">@s.FullName (@s.CollegeRollNo)</option> }
        </select></div>
        <button type="submit" class="btn btn-sm btn-primary w-100">Assign</button>
    </form></div></div>
</div>
</div>
