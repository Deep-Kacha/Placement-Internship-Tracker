@using PlacementTracker.Models
@{ ViewData["Title"] = "Manage Users";
    var students = ViewBag.Students as List<ApplicationUser> ?? new();
    var faculty = ViewBag.Faculty as List<ApplicationUser> ?? new();
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-person-plus me-2"></i>Manage Users</h5>
    <div class="d-flex gap-2">
        <a asp-action="CreateStudent" class="btn btn-primary btn-sm"><i class="bi bi-plus me-1"></i>Add Student</a>
        <a asp-action="CreateFaculty" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus me-1"></i>Add Faculty</a>
    </div>
</div>

<div class="row g-4">
<div class="col-md-7">
    <div class="card border-0 shadow-sm"><div class="card-body">
    <h6 class="fw-semibold mb-3">Students (@students.Count)</h6>
    <div class="table-responsive"><table class="table table-sm table-hover mb-0">
        <thead class="table-light"><tr><th>Name</th><th>Email</th><th>Department</th><th>Roll No</th><th>Approved</th><th>Active</th><th></th></tr></thead>
        <tbody>@foreach (var s in students){
        <tr class="@(!s.IsActive?"table-danger":"") @(!s.IsApproved?"table-warning":"")">
            <td class="fw-semibold">@s.FullName</td><td class="small">@s.Email</td>
            <td class="small">@s.Department</td><td class="small">@s.CollegeRollNo</td>
            <td>@if(s.IsApproved){<span class="badge bg-success">Yes</span>}else{<span class="badge bg-warning text-dark">Pending</span>}</td>
            <td>@if(s.IsActive){<span class="badge bg-success">Yes</span>}else{<span class="badge bg-danger">No</span>}</td>
            <td>
                @if(!s.IsApproved){
                    <form asp-action="ApproveStudent" method="post" class="d-inline">@Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@s.Id"/>
                        <button class="btn btn-xs btn-success me-1">Approve</button>
                    </form>
                }
                <form asp-action="ToggleUser" method="post" class="d-inline">@Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@s.Id"/>
                    <button class="btn btn-xs btn-outline-secondary">Toggle</button>
                </form>
            </td>
        </tr>}</tbody>
    </table></div></div></div>
</div>
<div class="col-md-5">
    <div class="card border-0 shadow-sm mb-3"><div class="card-body">
    <h6 class="fw-semibold mb-3">Faculty (@faculty.Count)</h6>
    <ul class="list-group list-group-flush">
    @foreach (var f in faculty){
    <li class="list-group-item d-flex justify-content-between align-items-center">
        <div><span class="fw-semibold">@f.FullName</span><br/><small class="text-muted">@f.Email · @f.Department</small></div>
        <form asp-action="ToggleUser" method="post">@Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@f.Id"/>
            <button class="btn btn-xs btn-outline-secondary">Toggle</button></form>
    </li>}
    </ul></div></div>

    <div class="card border-0 shadow-sm"><div class="card-body">
    <h6 class="fw-semibold mb-3">Assign Student → Faculty</h6>
    <form asp-action="AssignStudentToFaculty" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-2"><select name="facultyId" class="form-select form-select-sm" required>
            <option value="">Select Faculty</option>
            @foreach (var f in faculty){ <option value="@f.Id">@f.FullName</option> }
        </select></div>
        <div class="mb-2"><select name="studentId" class="form-select form-select-sm" required>
            <option value="">Select Student</option>
            @foreach (var s in students){ <option value="@s.Id">@s.FullName (@s.CollegeRollNo)</option> }
        </select></div>
        <button type="submit" class="btn btn-sm btn-primary w-100">Assign</button>
    </form></div></div>
</div>
</div>
