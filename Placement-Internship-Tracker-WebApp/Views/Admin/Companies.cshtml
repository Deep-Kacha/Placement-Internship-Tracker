@model List<PlacementTracker.Models.Company>
@{ ViewData["Title"] = "Companies"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-buildings me-2"></i>Companies</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addCompanyModal"><i class="bi bi-plus me-1"></i>Add Company</button>
</div>
<div class="card border-0 shadow-sm"><div class="table-responsive">
<table class="table table-hover table-sm mb-0">
    <thead class="table-light"><tr><th>Name</th><th>Location</th><th>Industry</th><th>Placements</th><th>Internships</th><th>Website</th></tr></thead>
    <tbody>@foreach (var c in Model){
    <tr><td class="fw-semibold">@c.Name</td><td class="small">@c.Location</td><td class="small">@c.Industry</td>
        <td>@if(c.OffersPlacement){<span class="badge bg-success">Yes</span>}else{<span class="text-muted">No</span>}</td>
        <td>@if(c.OffersInternships){<span class="badge bg-info">Yes</span>}else{<span class="text-muted">No</span>}</td>
        <td>@if(!string.IsNullOrEmpty(c.Website)){<a href="@c.Website" target="_blank" class="small">Visit ↗</a>}</td></tr>
    }</tbody>
</table></div></div>

<div class="modal fade" id="addCompanyModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
<div class="modal-header"><h6 class="modal-title fw-bold">Add Company</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
<form asp-action="AddCompany" method="post">@Html.AntiForgeryToken()
<div class="modal-body">
    <div class="mb-2"><label class="form-label fw-semibold">Name *</label><input name="name" class="form-control" required/></div>
    <div class="row g-2 mb-2"><div class="col"><label class="form-label fw-semibold">Location</label><input name="location" class="form-control"/></div>
        <div class="col"><label class="form-label fw-semibold">Industry</label><input name="industry" class="form-control"/></div></div>
    <div class="mb-2"><label class="form-label fw-semibold">Website</label><input name="website" class="form-control" type="url"/></div>
    <div class="form-check form-switch"><input name="offersPlacement" type="checkbox" value="true" checked class="form-check-input"/><label class="form-check-label">Offers Placement</label></div>
    <div class="form-check form-switch"><input name="offersInternships" type="checkbox" value="true" checked class="form-check-input"/><label class="form-check-label">Offers Internships</label></div>
</div>
<div class="modal-footer"><button type="submit" class="btn btn-primary">Add</button></div>
</form></div></div></div>
