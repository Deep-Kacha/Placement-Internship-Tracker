@model PlacementTracker.Models.JobDescription
@{ ViewData["Title"] = "JD Details"; }

<div class="mb-4">
    <a asp-action="JobDescriptions" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left me-1"></i>Back to JDs</a>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h4 class="fw-bold mb-1">@Model.Title</h4>
                <div class="text-muted"><i class="bi bi-building me-2"></i>@Model.CompanyName</div>
            </div>
            <span class="badge bg-@(Model.Status == "Approved" ? "success" : Model.Status == "Rejected" ? "danger" : "warning text-dark") fs-6 px-3 py-2">
                @Model.Status
            </span>
        </div>
        <p class="mb-4">@Model.Description</p>
        <div class="row g-4 mt-2">
            <div class="col-sm-3">
                <div class="text-muted small text-uppercase fw-bold mb-1">Type</div>
                <div class="fw-medium">@Model.JobType</div>
            </div>
            <div class="col-sm-3">
                <div class="text-muted small text-uppercase fw-bold mb-1">Annual CTC</div>
                <div class="fw-medium">@(Model.AnnualCTC ?? "-")</div>
            </div>
            <div class="col-sm-3">
                <div class="text-muted small text-uppercase fw-bold mb-1">Stipend / Month</div>
                <div class="fw-medium">@(string.IsNullOrEmpty(Model.Stipend) ? (Model.PackageOrStipend ?? "-") : Model.Stipend)</div>
            </div>
            @if (Model.JobType == "Internship")
            {
                <div class="col-sm-3">
                    <div class="text-muted small text-uppercase fw-bold mb-1">Internship Duration</div>
                    <div class="fw-medium text-dark">@(Model.InternshipDuration ?? "-")</div>
                </div>
            }
            <div class="col-sm-3">
                <div class="text-muted small text-uppercase fw-bold mb-1">Campus Drive</div>
                <div class="fw-medium text-primary">@(Model.CampusDriveDate?.ToString("dd MMM yyyy") ?? "-")</div>
            </div>
            <div class="col-sm-3">
                <div class="text-muted small text-uppercase fw-bold mb-1">Bond</div>
                <div class="fw-medium">@(Model.Bond ?? "None")</div>
            </div>
            <div class="col-sm-3">
                <div class="text-muted small text-uppercase fw-bold mb-1">Eligible Batches</div>
                <div class="fw-medium text-dark">@(Model.EligibleBatches ?? "All")</div>
            </div>
            <div class="col-sm-3">
                <div class="text-muted small text-uppercase fw-bold mb-1">Eligible Courses</div>
                <div class="fw-medium text-dark">@(Model.EligibleCourses ?? "All")</div>
            </div>
            <div class="col-sm-3">
                <div class="text-muted small text-uppercase fw-bold mb-1">Joining Date</div>
                <div class="fw-medium text-success">@(Model.DateOfJoining?.ToString("dd MMM yyyy") ?? "-")</div>
            </div>
            <div class="col-sm-3">
                <div class="text-muted small text-uppercase fw-bold mb-1">Deadline</div>
                <div class="fw-medium text-danger">@Model.Deadline.ToString("dd MMM yyyy")</div>
            </div>
        </div>

        <div class="row mt-4 pt-3 border-top">
            <div class="col-md-6 border-end">
                <h6 class="fw-bold mb-3"><i class="bi bi-person-badge me-2"></i>Contact Information</h6>
                <div class="mb-2"><strong>Name:</strong> @(Model.ContactName ?? "-")</div>
                <div class="mb-2"><strong>Email:</strong> @(Model.ContactEmail ?? "-")</div>
                <div class="mb-2"><strong>Mobile:</strong> @(Model.ContactMobile ?? "-")</div>
                @if (!string.IsNullOrEmpty(Model.CompanyWebsite))
                {
                    <div class="mb-2"><strong>Website:</strong> <a href="@Model.CompanyWebsite" target="_blank" class="text-decoration-none">@Model.CompanyWebsite <i class="bi bi-box-arrow-up-right small"></i></a></div>
                }
            </div>
            <div class="col-md-6 ps-md-4">
                <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Submission Details</h6>
                <div class="mb-2"><strong>Submitted On:</strong> @Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
                <div class="mb-2"><strong>Source:</strong> @(Model.RecruiterId != null ? "Registered Recruiter" : "Guest Submission")</div>
                @if (!string.IsNullOrEmpty(Model.DocumentsPath))
                {
                    <div class="mt-3">
                        <a href="@Model.DocumentsPath" target="_blank" class="btn btn-sm btn-outline-success"><i class="bi bi-file-earmark-pdf me-1"></i>Download JD Document</a>
                    </div>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.SelectionProcess)) {
            <div class="mt-4 pt-3 border-top">
                <div class="text-muted small text-uppercase fw-bold mb-2">Selection Process</div>
                <div class="p-3 bg-light rounded text-sm" style="white-space: pre-wrap;">@Model.SelectionProcess</div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.AdditionalDetails)) {
            <div class="mt-4 pt-3 border-top">
                <div class="text-muted small text-uppercase fw-bold mb-2">Additional Details</div>
                <div class="p-3 bg-light rounded text-sm" style="white-space: pre-wrap;">@Model.AdditionalDetails</div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.RegistrationLink)) {
            <div class="mt-4">
                <a href="@Model.RegistrationLink" target="_blank" class="btn btn-outline-primary"><i class="bi bi-link-45deg me-1"></i>Official Registration Link ↗</a>
            </div>
        }
    </div>
</div>

<h5 class="fw-bold mb-3 mt-5">Update Applicant Statuses</h5>
<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="BulkUpdateApplicantStatus" method="post">
            <input type="hidden" name="jdId" value="@Model.Id" />
            <div class="row align-items-end mb-4">
                <div class="col-md-4">
                    <label class="form-label fw-semibold text-sm">Update selected to:</label>
                    <select name="newStatus" class="form-select" required>
                        <option value="">-- Select Status --</option>
                        <option value="Shortlisted">Shortlisted</option>
                        <option value="Interview">Interview</option>
                        <option value="Offer">Offer</option>
                        <option value="Selected">Selected ✓</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Apply Status</button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th style="width: 40px;"><input type="checkbox" class="form-check-input" id="selectAll" /></th>
                            <th class="ps-2">Student Name</th>
                            <th>Roll No</th>
                            <th>Department</th>
                            <th>Current Status</th>
                            <th>Resume</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ 
                            var applicants = Model.JobType == "Internship" 
                                ? Model.InternshipApplications.Select(a => new { a.Student, a.Status }).ToList()
                                : Model.JobApplications.Select(a => new { a.Student, a.Status }).ToList();
                        }
                        @if(!applicants.Any()) {
                            <tr><td colspan="6" class="text-center py-5 text-muted">No applicants yet.</td></tr>
                        }
                        @foreach (var app in applicants) {
                            <tr>
                                <td><input type="checkbox" name="studentIds" value="@app.Student?.Id" class="form-check-input student-chk" /></td>
                                <td class="ps-2 fw-semibold">@app.Student?.FullName</td>
                                <td><code>@app.Student?.CollegeRollNo</code></td>
                                <td>@app.Student?.Department</td>
                                <td><span class="badge bg-light text-dark border">@app.Status</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(app.Student?.ResumePath))
                                    {
                                        <a asp-controller="Account" asp-action="DownloadResume" asp-route-id="@app.Student.Id" class="btn btn-sm btn-outline-primary" title="Download Resume">
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById('selectAll').addEventListener('change', function(e) {
        document.querySelectorAll('.student-chk').forEach(c => c.checked = e.target.checked);
    });
</script>
