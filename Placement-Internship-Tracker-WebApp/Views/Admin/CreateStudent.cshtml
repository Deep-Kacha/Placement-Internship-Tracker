@model PlacementTracker.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Create Student"; }
<div class="row justify-content-center"><div class="col-md-8">
<div class="card border-0 shadow-sm"><div class="card-body">
<h5 class="fw-bold mb-3"><i class="bi bi-person-plus me-2"></i>Create Student Account</h5>
<form asp-action="CreateStudent" method="post">
    <div asp-validation-summary="All" class="text-danger small mb-2"></div>
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="FullName" class="form-label fw-semibold"></label><input asp-for="FullName" class="form-control"/></div>
        <div class="col-md-6"><label asp-for="Email" class="form-label fw-semibold"></label><input asp-for="Email" class="form-control"/></div>
        <div class="col-md-6"><label asp-for="Password" class="form-label fw-semibold"></label><input asp-for="Password" class="form-control" type="password"/></div>
        <div class="col-md-6"><label asp-for="ConfirmPassword" class="form-label fw-semibold"></label><input asp-for="ConfirmPassword" class="form-control" type="password"/></div>
        <div class="col-md-4"><label asp-for="Department" class="form-label fw-semibold"></label>
            <select asp-for="Department" class="form-select"><option value="">—</option>
                <option>Computer Science</option><option>Information Technology</option>
                <option>Electronics</option><option>Mechanical</option><option>Civil</option><option>MBA</option>
            </select></div>
        <div class="col-md-4"><label class="form-label fw-semibold">Roll No</label><input asp-for="CollegeRollNo" class="form-control"/></div>
        <div class="col-md-4"><label asp-for="Phone" class="form-label fw-semibold"></label><input asp-for="Phone" class="form-control"/></div>
    </div>
    <input type="hidden" asp-for="Role" value="Student"/>
    <div class="mt-3"><button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Create</button>
        <a asp-action="Users" class="btn btn-outline-secondary ms-2">Cancel</a></div>
</form></div></div></div></div>
