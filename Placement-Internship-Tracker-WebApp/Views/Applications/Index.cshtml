@model List<PlacementTracker.Models.JobApplication>
@{ ViewData["Title"] = "Job Applications"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-briefcase me-2"></i>My Job Applications</h5>
    <div class="d-flex gap-2">
        <a asp-action="ExportExcel" class="btn btn-outline-success btn-sm"><i class="bi bi-file-earmark-excel me-1"></i>Export</a>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus me-1"></i>New</a>
    </div>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-3">
<div class="card-body py-2">
<form method="get" class="row g-2 align-items-end">
    <div class="col-auto">
        <select name="status" class="form-select form-select-sm">
            <option value="">All Status</option>
            @foreach (var s in ViewBag.StatusList as List<string> ?? new())
            { if (ViewBag.Filter_Status == s) { <option value="@s" selected>@s</option> } else { <option value="@s">@s</option> } }
        </select>
    </div>
    <div class="col-auto"><input name="company" class="form-control form-control-sm" placeholder="Company..." value="@ViewBag.Filter_Company"/></div>
    <div class="col-auto"><input name="from" type="date" class="form-control form-control-sm" value="@ViewBag.Filter_From"/></div>
    <div class="col-auto"><input name="to" type="date" class="form-control form-control-sm" value="@ViewBag.Filter_To"/></div>
    <div class="col-auto d-flex gap-1">
        <button type="submit" class="btn btn-primary btn-sm">Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
    </div>
</form>
</div>
</div>

<div class="card border-0 shadow-sm">
<div class="table-responsive">
<table class="table table-hover table-sm mb-0">
    <thead class="table-light">
    <tr>
        <th>Company</th><th>Role</th><th>Status</th><th>Applied</th><th>Package</th><th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var a in Model)
    {
    <tr>
        <td class="fw-semibold">@a.CompanyName</td>
        <td class="small">@a.Role</td>
        <td><span class="badge badge-@a.Status">@a.Status</span></td>
        <td class="small text-muted">@a.AppliedDate.ToString("dd MMM yyyy")</td>
        <td class="small">@(a.Package ?? "—")</td>
        <td>
            <div class="d-flex gap-1">
                <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-xs btn-outline-primary" title="View"><i class="bi bi-eye"></i></a>
                <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-xs btn-outline-warning" title="Edit"><i class="bi bi-pencil"></i></a>
                <form asp-action="Delete" method="post" onsubmit="return confirm('Remove?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@a.Id"/>
                    <button class="btn btn-xs btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                </form>
            </div>
        </td>
    </tr>
    }
    </tbody>
</table>
</div>
</div>
@if (!Model.Any()){ <p class="text-muted text-center mt-3">No applications found. <a asp-action="Create">Create your first one!</a></p> }
