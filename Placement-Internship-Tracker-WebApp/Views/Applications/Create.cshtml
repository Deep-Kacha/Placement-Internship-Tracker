@model PlacementTracker.ViewModels.ApplicationFormViewModel
@{ ViewData["Title"] = "New Application"; }
<div class="row justify-content-center"><div class="col-md-8">
<div class="card border-0 shadow-sm">
<div class="card-body">
<h5 class="fw-bold mb-3"><i class="bi bi-plus-circle me-2"></i>New Job Application</h5>
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger small mb-2"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="CompanyName" class="form-label fw-semibold"></label>
            <input asp-for="CompanyName" class="form-control" placeholder="e.g. Google"/>
        </div>
        <div class="col-md-6">
            <label asp-for="Role" class="form-label fw-semibold"></label>
            <input asp-for="Role" class="form-control" placeholder="e.g. SDE-1"/>
        </div>
        <div class="col-md-4">
            <label asp-for="Status" class="form-label fw-semibold"></label>
            <select asp-for="Status" class="form-select">
                @foreach (var s in ViewBag.StatusList as List<string> ?? new()) { <option>@s</option> }
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="AppliedDate" class="form-label fw-semibold"></label>
            <input asp-for="AppliedDate" class="form-control" type="date"/>
        </div>
        <div class="col-md-4">
            <label asp-for="Package" class="form-label fw-semibold"></label>
            <input asp-for="Package" class="form-control" placeholder="e.g. 6 LPA"/>
        </div>
        <div class="col-md-6">
            <label asp-for="Location" class="form-label fw-semibold"></label>
            <input asp-for="Location" class="form-control" placeholder="City"/>
        </div>
        <div class="col-md-6">
            <label asp-for="JobLink" class="form-label fw-semibold">Job Link</label>
            <input asp-for="JobLink" class="form-control" placeholder="https://..."/>
        </div>
        <div class="col-12">
            <label asp-for="Notes" class="form-label fw-semibold"></label>
            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Any notes..."></textarea>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
</div></div></div></div>
