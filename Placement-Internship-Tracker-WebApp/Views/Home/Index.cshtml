@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Trackeoo | The Ultimate Placement & Internship Platform</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#fef2f2',
                            100: '#fee2e2',
                            200: '#fecaca',
                            300: '#fca5a5',
                            400: '#f87171',
                            500: '#ef4444',
                            600: '#dc2626',
                            700: '#B91C1C', // Primary
                            800: '#991b1b',
                            900: '#7F1D1D', // Primary Dark
                        },
                        cream: {
                            50: '#FFFBF5',
                            100: '#FFF7ED', // Secondary
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #FFFBF5; }
        .glass-nav { background: rgba(255, 251, 245, 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(229, 231, 235, 0.5); }
        .hero-pattern { background-image: radial-gradient(#dc2626 0.5px, transparent 0.5px); background-size: 24px 24px; opacity: 0.1; }
        .gradient-text { background: linear-gradient(to right, #B91C1C, #ef4444); -webkit-background-clip: text; color: transparent; }
    </style>
</head>

<body class="text-gray-900 bg-cream-50 antialiased overflow-x-hidden selection:bg-brand-200 selection:text-brand-900">

    <!-- Navbar -->
    <nav class="fixed w-full z-50 glass-nav transition-all duration-300">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="flex items-center gap-2 group">
                <div class="w-8 h-8 rounded-lg bg-brand-700 text-white flex items-center justify-center font-bold text-xl group-hover:bg-brand-800 transition">
                    <i class="bi bi-mortarboard-fill text-sm"></i>
                </div>
                <span class="text-2xl font-extrabold tracking-tight text-gray-900">Trackeoo</span>
            </a>

            <ul class="hidden md:flex space-x-10 font-medium text-gray-600">
                <li><a href="#roles" class="hover:text-brand-700 transition">For Roles</a></li>
                <li><a href="#roadmap" class="hover:text-brand-700 transition">Roadmap</a></li>
                <li><a href="#features" class="hover:text-brand-700 transition">Features</a></li>
                <li><a href="/Home/SubmitJd" class="hover:text-brand-700 transition font-semibold">Submit JD</a></li>
            </ul>

            <div class="flex items-center gap-4">
                <a href="/Account/Login" class="text-gray-700 font-medium hover:text-brand-700 hidden sm:block transition">Log in</a>
                <a href="/Account/Login" class="bg-gray-900 text-white px-5 py-2.5 rounded-xl font-medium hover:bg-brand-700 transition shadow-lg shadow-gray-900/20">
                    Get Started
                </a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
        <div class="absolute inset-0 hero-pattern z-0"></div>
        <div class="max-w-7xl mx-auto px-6 relative z-10 grid lg:grid-cols-2 gap-16 items-center">
            <div class="max-w-xl">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 border border-brand-100 text-brand-700 text-sm font-semibold mb-6">
                    <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
                    Powering Smarter Placement Operations
                </div>
                <h1 class="text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
                    Streamline your <span class="gradient-text">internship and job tracking.</span>
                </h1>
                <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                    Trackeoo helps synchronize students, faculty, and recruiters. Get real-time updates on applications, interviews, and offers in one unified platform.
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="/Account/Login" class="bg-brand-700 text-white px-8 py-3.5 rounded-xl font-medium text-lg hover:bg-brand-800 transition shadow-xl shadow-brand-500/30 flex items-center justify-center gap-2">
                        Start Tracking Free
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a href="#features" class="bg-white text-gray-800 border border-gray-200 px-8 py-3.5 rounded-xl font-medium text-lg hover:bg-gray-50 transition flex items-center justify-center">
                        Explore Features
                    </a>
                </div>
            </div>

            <div class="relative">
                <!-- Abstract visual representation of application tracker -->
                <div class="relative w-full h-[500px] bg-white rounded-3xl shadow-2xl border border-gray-100 overflow-hidden">
                    <div class="bg-gray-50 border-b border-gray-100 p-4 flex gap-2">
                        <div class="w-3 h-3 rounded-full bg-red-400"></div>
                        <div class="w-3 h-3 rounded-full bg-amber-400"></div>
                        <div class="w-3 h-3 rounded-full bg-green-400"></div>
                    </div>
                    <div class="p-6">
                        <div class="flex justify-between items-center mb-6">
                            <div class="h-6 w-32 bg-gray-200 rounded-md"></div>
                            <div class="h-8 w-8 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center"><i class="bi bi-person-fill"></i></div>
                        </div>
                        <div class="space-y-4">
                            <!-- Google -->
                            <div class="p-4 border border-gray-200 rounded-xl bg-white shadow-sm flex items-center justify-between">
                                <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center text-gray-600 text-xl">
                                    <i class="bi bi-google"></i>
                                </div>
                                <div>
                                    <div class="text-gray-900 font-semibold">Google</div>
                                    <div class="text-sm text-gray-500">Software Engineer</div>
                                </div>
                                </div>
                                <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-semibold">
                                Offer Received
                                </span>
                            </div>
                            <!-- Microsoft -->
                            <div class="p-4 border border-blue-200 rounded-xl bg-blue-50 shadow-sm flex items-center justify-between">
                                <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-white border border-blue-200 rounded-lg flex items-center justify-center text-blue-600 text-xl">
                                    <i class="bi bi-microsoft"></i>
                                </div>
                                <div>
                                    <div class="text-blue-900 font-semibold">Microsoft</div>
                                    <div class="text-sm text-blue-600">Product Manager</div>
                                </div>
                                </div>
                                <span class="px-3 py-1 bg-blue-600 text-white rounded-full text-xs font-semibold">
                                Interviewing
                                </span>
                            </div>
                            <!-- Amazon -->
                            <div class="p-4 border border-gray-200 rounded-xl bg-white shadow-sm flex items-center justify-between">
                                <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center text-gray-600 text-xl">
                                    <i class="bi bi-amazon"></i>
                                </div>
                                <div>
                                    <div class="text-gray-900 font-semibold">Amazon</div>
                                    <div class="text-sm text-gray-500">Sales Associate</div>
                                </div>
                                </div>
                                <span class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-full text-xs font-semibold">
                                Screening
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Floating Elements -->
                <div class="absolute -bottom-6 -left-6 bg-white p-4 rounded-xl shadow-xl border border-gray-100 flex items-center gap-4 animate-bounce" style="animation-duration: 3s;">
                    <div class="w-10 h-10 rounded-full bg-green-100 text-green-600 flex items-center justify-center">
                        <i class="bi bi-check-lg text-xl"></i>
                    </div>
                    <div>
                        <div class="text-xs text-gray-500 font-medium">Status Update</div>
                        <div class="text-sm font-bold text-gray-900">Deep accepted the offer!</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Every Role Section -->
    <section id="roles" class="py-24 bg-gray-900 text-white">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-16">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gray-800 text-brand-400 text-sm font-semibold mb-4">
                    <i class="bi bi-people-fill"></i> For Every Role
                </div>
                <h2 class="text-4xl font-bold mb-4">Smart tools for students, faculty, and admins.</h2>
                <p class="text-gray-400 text-lg">Trackeoo adapts to your needs, whether you are applying for jobs, mentoring students, or managing campus drives.</p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <!-- Card 1 -->
                <div class="bg-gray-800 border border-gray-700 rounded-2xl p-8 hover:border-brand-500 transition-colors group">
                    <div class="w-14 h-14 bg-gray-700 rounded-xl flex items-center justify-center text-3xl mb-6 group-hover:bg-brand-600 group-hover:text-white transition-colors text-brand-400">
                        <i class="bi bi-person-workspace"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Students</h3>
                    <p class="text-gray-400 mb-6 leading-relaxed">
                        Track every application from applied to hired. Organize your interview schedules, documents, and offers effortlessly.
                    </p>
                    <a href="/Account/Register" class="text-brand-400 font-semibold group-hover:text-brand-300 flex items-center gap-2 transition-colors">
                        Learn More <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                <!-- Card 2 -->
                <div class="bg-gray-800 border border-gray-700 rounded-2xl p-8 hover:border-brand-500 transition-colors group">
                    <div class="w-14 h-14 bg-gray-700 rounded-xl flex items-center justify-center text-3xl mb-6 group-hover:bg-brand-600 group-hover:text-white transition-colors text-brand-400">
                        <i class="bi bi-person-video3"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Faculty Mentors</h3>
                    <p class="text-gray-400 mb-6 leading-relaxed">
                        Monitor your assigned students' progress. View their applications and provide timely guidance to boost their success rate.
                    </p>
                    <a href="/Account/Register" class="text-brand-400 font-semibold group-hover:text-brand-300 flex items-center gap-2 transition-colors">
                        Learn More <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                <!-- Card 3 -->
                <div class="bg-gray-800 border border-gray-700 rounded-2xl p-8 hover:border-brand-500 transition-colors group">
                    <div class="w-14 h-14 bg-gray-700 rounded-xl flex items-center justify-center text-3xl mb-6 group-hover:bg-brand-600 group-hover:text-white transition-colors text-brand-400">
                        <i class="bi bi-pie-chart-fill"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3">Administrators</h3>
                    <p class="text-gray-400 mb-6 leading-relaxed">
                        Get a bird's-eye view of campus placements. Generate reports, manage companies, and streamline the entire process.
                    </p>
                    <a href="/Account/Register" class="text-brand-400 font-semibold group-hover:text-brand-300 flex items-center gap-2 transition-colors">
                        Learn More <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Custom Roadmaps (Tabs representation) -->
    <section id="roadmap" class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-16">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 border border-brand-100 text-brand-700 text-sm font-semibold mb-4">
                    <i class="bi bi-map-fill"></i> Custom Workflows
                </div>
                <h2 class="text-4xl font-bold mb-4">Track applications from applied to hired</h2>
            </div>
            
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div class="space-y-6">
                    <!-- Tab Items (Visual) -->
                    <div class="p-6 rounded-2xl bg-brand-50 border-2 border-brand-600 cursor-pointer transition">
                        <h4 class="text-lg font-bold text-gray-900 mb-2">Build workflows unique to your process</h4>
                        <p class="text-gray-600">Efficiently track and manage applications live from initial screening to the final offer letter.</p>
                    </div>
                    <div class="p-6 rounded-2xl bg-white border border-gray-100 hover:border-gray-300 cursor-pointer transition shadow-sm">
                        <h4 class="text-lg font-bold text-gray-900 mb-2">Manage everything in one dashboard</h4>
                        <p class="text-gray-600">Control statuses, documents, schedules, and communication all from a unified interface.</p>
                    </div>
                    <div class="p-6 rounded-2xl bg-white border border-gray-100 hover:border-gray-300 cursor-pointer transition shadow-sm">
                        <h4 class="text-lg font-bold text-gray-900 mb-2">Seamless analytics updates</h4>
                        <p class="text-gray-600">Watch your placement metrics update in real-time securely within Trackeoo.</p>
                    </div>
                </div>

                <div class="bg-gray-50 rounded-3xl p-8 border border-gray-200">
                    <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71" alt="Dashboard Workflow" class="rounded-xl shadow-lg border border-gray-200 w-full" />
                </div>
            </div>
        </div>
    </section>

    <!-- Integrations/Stats -->
    <section id="features" class="py-24 bg-cream-100 border-t border-cream-200 relative overflow-hidden">
        <div class="absolute inset-0 opacity-50 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] mix-blend-multiply"></div>
        <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
            <h2 class="text-3xl font-bold mb-12">Empowering Institutions & Students Globally</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-cream-200">
                    <div class="text-4xl font-extrabold text-brand-600 mb-2">10k+</div>
                    <div class="text-gray-600 font-medium">Students Placed</div>
                </div>
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-cream-200">
                    <div class="text-4xl font-extrabold text-brand-600 mb-2">500+</div>
                    <div class="text-gray-600 font-medium">Top Companies</div>
                </div>
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-cream-200">
                    <div class="text-4xl font-extrabold text-gray-900 mb-2">99%</div>
                    <div class="text-gray-600 font-medium">Uptime Tracking</div>
                </div>
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-cream-200">
                    <div class="text-4xl font-extrabold text-gray-900 mb-2">24/7</div>
                    <div class="text-gray-600 font-medium">System Support</div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="py-24 bg-cream-50">
        <div class="max-w-3xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-bold mb-4">Answers to common questions</h2>
            </div>
            
            <div class="space-y-4">
                <details class="bg-white rounded-xl shadow-sm border border-gray-100 [&_summary::-webkit-details-marker]:hidden group">
                    <summary class="flex items-center justify-between p-6 cursor-pointer font-bold text-lg">
                        How does Trackeoo improve placements?
                        <span class="transition group-open:rotate-180">
                            <i class="bi bi-chevron-down"></i>
                        </span>
                    </summary>
                    <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100 pt-4 mt-2">
                        Trackeoo provides admins and faculty with a real-time view of every student's application status. This allows for smarter intervention, optimized interview preparation, and direct communication, leading to increased success rates.
                    </div>
                </details>
                
                <details class="bg-white rounded-xl shadow-sm border border-gray-100 [&_summary::-webkit-details-marker]:hidden group">
                    <summary class="flex items-center justify-between p-6 cursor-pointer font-bold text-lg">
                        Is Trackeoo suitable for small institutions?
                        <span class="transition group-open:rotate-180">
                            <i class="bi bi-chevron-down"></i>
                        </span>
                    </summary>
                    <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100 pt-4 mt-2">
                        Absolutely. Trackeoo is built to scale, offering flexible plans perfect for individual departments or entire universities.
                    </div>
                </details>

                <details class="bg-white rounded-xl shadow-sm border border-gray-100 [&_summary::-webkit-details-marker]:hidden group">
                    <summary class="flex items-center justify-between p-6 cursor-pointer font-bold text-lg">
                        Can students track roles outside of campus drives?
                        <span class="transition group-open:rotate-180">
                            <i class="bi bi-chevron-down"></i>
                        </span>
                    </summary>
                    <div class="px-6 pb-6 text-gray-600 leading-relaxed border-t border-gray-100 pt-4 mt-2">
                        Yes! Students can manually add off-campus internship and placement opportunities to keep their entire job hunt organized in one central hub.
                    </div>
                </details>
            </div>
        </div>
    </section>

    <!-- CTA Footer -->
    <section class="bg-gray-900 text-white relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-brand-500 to-transparent"></div>
        <div class="py-20 px-6 max-w-7xl mx-auto text-center border-b border-gray-800">
            <h2 class="text-4xl font-bold mb-6">Delivering Better Careers Across Every Campus</h2>
            <p class="text-gray-400 max-w-2xl mx-auto mb-10 text-lg">Empower your students, connect campus mentors, and make every placement smarter and more impactful with Trackeoo.</p>
            <a href="/Account/Register" class="inline-flex items-center gap-2 bg-brand-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-brand-500 transition shadow-lg shadow-brand-600/30">
                Get Started Now <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        
        <footer class="max-w-7xl mx-auto px-6 py-12">
            <div class="grid md:grid-cols-4 gap-8 mb-12">
                <div class="col-span-2">
                    <div class="flex items-center gap-2 mb-4 text-white">
                        <i class="bi bi-mortarboard-fill text-xl"></i>
                        <span class="text-2xl font-bold">Trackeoo</span>
                    </div>
                    <p class="text-gray-400 max-w-sm mb-6">Trackeoo powers smarter placements through real-time tracking, seamless scheduling, and unified campus operations.</p>
                    <div class="flex gap-4">
                        <a href="#" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center hover:bg-brand-600 transition"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center hover:bg-brand-600 transition"><i class="bi bi-linkedin"></i></a>
                        <a href="#" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center hover:bg-brand-600 transition"><i class="bi bi-github"></i></a>
                    </div>
                </div>
                
                <div>
                    <h4 class="font-bold mb-4 text-white">Platform</h4>
                    <ul class="space-y-3 text-gray-400">
                        <li><a href="#features" class="hover:text-white transition">Features</a></li>
                        <li><a href="#" class="hover:text-white transition">About Us</a></li>
                        <li><a href="/Account/Login" class="hover:text-white transition">Login</a></li>
                    </ul>
                </div>
                
                <div>
                    <h4 class="font-bold mb-4 text-white">Legal</h4>
                    <ul class="space-y-3 text-gray-400">
                        <li><a href="#" class="hover:text-white transition">Privacy Policy</a></li>
                        <li><a href="#" class="hover:text-white transition">Terms of Service</a></li>
                        <li><a href="#" class="hover:text-white transition">Contact Support</a></li>
                    </ul>
                </div>
            </div>
            
            <div class="text-center text-gray-600 text-sm">
                &copy; @DateTime.Now.Year Trackeoo. All rights reserved.
            </div>
        </footer>
    </section>

</body>
</html>