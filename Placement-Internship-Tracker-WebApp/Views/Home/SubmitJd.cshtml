@model PlacementTracker.ViewModels.JobDescriptionViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Submit Job Description | Trackeoo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#fef2f2', 100: '#fee2e2', 200: '#fecaca', 300: '#fca5a5',
                            400: '#f87171', 500: '#ef4444', 600: '#dc2626', 700: '#B91C1C',
                            800: '#991b1b', 900: '#7F1D1D',
                        },
                        cream: { 50: '#FFFBF5', 100: '#FFF7ED' }
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #FFFBF5; }
        .form-section { background: white; border-radius: 1.5rem; border: 1px solid #f3f4f6; padding: 2rem; margin-bottom: 2rem; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); }
        .input-field { width: 100%; padding: 0.75rem 1rem; border-radius: 0.75rem; border: 1px solid #e5e7eb; outline: none; transition: all 0.2s; }
        .input-field:focus { border-color: #B91C1C; ring: 2px; ring-color: #fca5a5; }
        .btn-primary { background-color: #B91C1C; color: white; padding: 0.75rem 2rem; border-radius: 0.75rem; font-weight: 600; transition: all 0.2s; }
        .btn-primary:hover { background-color: #991b1b; transform: translateY(-1px); }
    </style>
</head>
<body class="text-gray-900 bg-cream-50 antialiased">

    <!-- Navbar -->
    <nav class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-gray-100">
        <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg bg-brand-700 text-white flex items-center justify-center font-bold">
                    <i class="bi bi-mortarboard-fill text-sm"></i>
                </div>
                <span class="text-xl font-bold tracking-tight">Trackeoo</span>
            </a>
            <a href="/" class="text-gray-600 hover:text-brand-700 font-medium">Back to Home</a>
        </div>
    </nav>

    <div class="max-w-4xl mx-auto px-6 py-12">
        <header class="text-center mb-12">
            <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Submit Job Description</h1>
            <p class="text-gray-600 text-lg">Partner with RK University's T&P Cell to recruit top talent.</p>
        </header>

        <form asp-action="SubmitJd" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Company Information -->
            <div class="form-section">
                <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                    <i class="bi bi-building text-brand-600"></i> Company Details
                </h3>
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Company Name *</label>
                        <input asp-for="CompanyName" class="input-field" placeholder="e.g. Google" required />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Company Website</label>
                        <input asp-for="CompanyWebsite" class="input-field" placeholder="https://example.com" />
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Job Location *</label>
                        <input asp-for="Location" class="input-field" placeholder="e.g. Ahmedabad, Remote" required />
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Short Company/Job Description *</label>
                        <textarea asp-for="Description" class="input-field" rows="3" placeholder="Tell us about the company and the role" required></textarea>
                    </div>
                </div>
            </div>

            <!-- Job Role & Compensation -->
            <div class="form-section">
                <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                    <i class="bi bi-briefcase text-brand-600"></i> Role & Compensation
                </h3>
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Job Title / Position *</label>
                        <input asp-for="Title" class="input-field" placeholder="e.g. Software Engineer" required />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Job Type *</label>
                        <select asp-for="JobType" class="input-field" required>
                            <option value="Placement">Full-Time Placement</option>
                            <option value="Internship">Internship</option>
                            <option value="Both">Both (PPO)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Annual CTC (for Placements)</label>
                        <input asp-for="AnnualCTC" class="input-field" placeholder="e.g. 6 LPA - 8 LPA" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Monthly Stipend (for Internships)</label>
                        <input asp-for="Stipend" class="input-field" placeholder="e.g. 15,000 / month" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Internship Duration</label>
                        <input asp-for="InternshipDuration" class="input-field" placeholder="e.g. 6 Months" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Bond (if any)</label>
                        <input asp-for="Bond" class="input-field" placeholder="e.g. 2 Years" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Date of Joining *</label>
                        <input asp-for="DateOfJoining" type="date" class="input-field" required />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Application Deadline *</label>
                        <input asp-for="Deadline" type="date" class="input-field" required />
                    </div>
                </div>
            </div>

            <!-- Eligibility & Process -->
            <div class="form-section">
                <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                    <i class="bi bi-ui-checks text-brand-600"></i> Eligibility & Selection
                </h3>
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Eligible Batches *</label>
                        <div class="flex flex-wrap gap-4 bg-gray-50 p-4 rounded-xl">
                            @foreach (var batch in new[] { "2025", "2024", "2023" })
                            {
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" name="SelectedBatches" value="@batch" class="w-4 h-4 text-brand-600 rounded focus:ring-brand-500" />
                                    <span>@batch</span>
                                </label>
                            }
                        </div>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Eligible Courses *</label>
                        <div class="flex flex-wrap gap-4 bg-gray-50 p-4 rounded-xl">
                            @foreach (var course in new[] { "B.Tech CE", "B.Tech IT", "Mechanical", "Civil", "BCA", "MCA", "MBA" })
                            {
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="checkbox" name="SelectedCourses" value="@course" class="w-4 h-4 text-brand-600 rounded focus:ring-brand-500" />
                                    <span>@course</span>
                                </label>
                            }
                        </div>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Selection Process *</label>
                        <textarea asp-for="SelectionProcess" class="input-field" rows="3" placeholder="Step 1: Aptitude, Step 2: Technical, Step 3: HR" required></textarea>
                    </div>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="form-section">
                <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                    <i class="bi bi-person-lines-fill text-brand-600"></i> Contact Person
                </h3>
                <div class="grid md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Name *</label>
                        <input asp-for="ContactName" class="input-field" placeholder="John Doe" required />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Email *</label>
                        <input asp-for="ContactEmail" type="email" class="input-field" placeholder="john@company.com" required />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Mobile *</label>
                        <input asp-for="ContactMobile" class="input-field" placeholder="+91 9876543210" required />
                    </div>
                </div>
            </div>

            <!-- Attachments -->
            <div class="form-section">
                <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                    <i class="bi bi-paperclip text-brand-600"></i> Attachments
                </h3>
                <div class="p-8 border-2 border-dashed border-gray-200 rounded-2xl text-center bg-gray-50">
                    <i class="bi bi-cloud-arrow-up text-4xl text-gray-400 mb-4 block"></i>
                    <p class="text-gray-600 mb-4">Upload detailed JD Document (PDF/Word)</p>
                    <input asp-for="Document" type="file" class="mx-auto block" />
                </div>
            </div>

            <div class="text-center pb-20">
                <button type="submit" class="btn-primary w-full md:w-auto text-lg shadow-xl shadow-brand-500/30">
                    Submit Job Description
                </button>
                <p class="mt-4 text-sm text-gray-500">Upon submission, our Training & Placement officers will review the details and contact you for further process.</p>
            </div>
        </form>
    </div>

</body>
</html>
