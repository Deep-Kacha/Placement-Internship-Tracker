@model PlacementTracker.ViewModels.InternshipFormViewModel
@{ ViewData["Title"] = "New Internship"; }
<div class="row justify-content-center"><div class="col-md-10">
<div class="card border-0 shadow-sm"><div class="card-body">
<h5 class="fw-bold mb-3"><i class="bi bi-plus-circle me-2"></i>New Internship Application</h5>
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger small mb-2"></div>
    <div class="row g-3">
        <div class="col-md-4"><label asp-for="CompanyName" class="form-label fw-semibold"></label>
            <input asp-for="CompanyName" class="form-control" placeholder="e.g. Flipkart"/></div>
        <div class="col-md-4"><label asp-for="Role" class="form-label fw-semibold"></label>
            <input asp-for="Role" class="form-control" placeholder="e.g. SDE Intern"/></div>
        <div class="col-md-4"><label asp-for="InternshipType" class="form-label fw-semibold"></label>
            <select asp-for="InternshipType" class="form-select">
                @foreach (var t in ViewBag.TypeList as List<string> ?? new()){ <option>@t</option> }
            </select></div>
        <div class="col-md-4"><label asp-for="WorkMode" class="form-label fw-semibold"></label>
            <select asp-for="WorkMode" class="form-select">
                @foreach (var m in ViewBag.ModeList as List<string> ?? new()){ <option>@m</option> }
            </select></div>
        <div class="col-md-4"><label asp-for="Status" class="form-label fw-semibold"></label>
            <select asp-for="Status" class="form-select">
                @foreach (var s in ViewBag.StatusList as List<string> ?? new()){ <option>@s</option> }
            </select></div>
        <div class="col-md-4"><label asp-for="AppliedDate" class="form-label fw-semibold"></label>
            <input asp-for="AppliedDate" class="form-control" type="date"/></div>
        <div class="col-md-3"><label asp-for="StartDate" class="form-label fw-semibold"></label>
            <input asp-for="StartDate" class="form-control" type="date"/></div>
        <div class="col-md-3"><label asp-for="EndDate" class="form-label fw-semibold"></label>
            <input asp-for="EndDate" class="form-control" type="date"/></div>
        <div class="col-md-3"><label asp-for="Stipend" class="form-label fw-semibold"></label>
            <input asp-for="Stipend" class="form-control" placeholder="e.g. 25000"/></div>
        <div class="col-md-3"><label asp-for="Location" class="form-label fw-semibold"></label>
            <input asp-for="Location" class="form-control" placeholder="City"/></div>
        <div class="col-md-6"><label asp-for="JobLink" class="form-label fw-semibold">Portal Link</label>
            <input asp-for="JobLink" class="form-control" placeholder="https://..."/></div>
        <div class="col-md-6"><label asp-for="Notes" class="form-label fw-semibold"></label>
            <textarea asp-for="Notes" class="form-control" rows="1"></textarea></div>
        <div class="col-md-4">
            <div class="form-check form-switch mt-3">
                <input asp-for="IsFullTimeOffered" class="form-check-input" type="checkbox"/>
                <label class="form-check-label fw-semibold">Full-time Offer</label>
            </div></div>
        <div class="col-md-4"><label asp-for="FullTimePackage" class="form-label fw-semibold"></label>
            <input asp-for="FullTimePackage" class="form-control" placeholder="e.g. 8 LPA"/></div>
        <div class="col-md-4">
            <div class="form-check form-switch mt-3">
                <input asp-for="CertificateReceived" class="form-check-input" type="checkbox"/>
                <label class="form-check-label fw-semibold">Certificate Received</label>
            </div></div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
</div></div></div></div>
