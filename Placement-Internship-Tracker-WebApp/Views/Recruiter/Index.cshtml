@model IEnumerable<PlacementTracker.Models.JobDescription>
@{ ViewData["Title"] = "My Job Postings"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Job Postings</h4>
    <a asp-action="CreateJD" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle me-2"></i>Post New Job
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Job Title</th>
                        <th>Company</th>
                        <th>Type</th>
                        <th>Deadline</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(!Model.Any()) {
                        <tr><td colspan="6" class="text-center py-5 text-muted">No jobs posted yet.</td></tr>
                    }
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4 fw-semibold text-dark">@item.Title</td>
                            <td>@item.CompanyName</td>
                            <td><span class="badge bg-light text-dark border">@item.JobType</span></td>
                            <td>@item.Deadline.ToString("dd MMM yyyy")</td>
                            <td>
                                @if(item.Status == "Approved") { <span class="badge bg-success">Approved</span> }
                                else if(item.Status == "Rejected") { <span class="badge bg-danger">Rejected</span> }
                                else { <span class="badge bg-warning text-dark">Pending</span> }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border group">
                                    <i class="bi bi-eye"></i> Applicants
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
