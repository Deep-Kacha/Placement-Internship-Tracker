@model PlacementTracker.ViewModels.FacultyDashboardViewModel
@{ ViewData["Title"] = "Faculty Dashboard"; }
<h4 class="fw-bold mb-4"><i class="bi bi-people me-2"></i>Faculty Dashboard</h4>

<div class="row g-3 mb-4">
@foreach (var (label,val,color,icon) in new[]{
    ("My Students", (object)Model.TotalStudents, "primary", "people"),
    ("Total Placements", (object)Model.TotalApplications, "info", "briefcase"),
    ("Offers", (object)Model.TotalOffers, "success", "trophy"),
    ("Total Internships", (object)Model.TotalInternships, "warning", "building"),
    ("Internship Selected", (object)Model.TotalInternshipSelected, "teal", "check-circle"),
    ("FTO Offered", (object)Model.TotalFullTimeOffered, "danger", "star-fill"),
}){
<div class="col-6 col-md-2">
    <div class="card border-0 shadow-sm text-center p-3">
        <i class="bi bi-@icon fs-3 text-@color"></i>
        <div class="fs-3 fw-bold text-@color">@val</div>
        <small class="text-muted">@label</small>
    </div>
</div>
}
</div>

<div class="card border-0 shadow-sm mb-4"><div class="card-body">
<h6 class="fw-semibold mb-3">Students</h6>
<div class="table-responsive">
<table class="table table-hover table-sm mb-0">
    <thead class="table-light"><tr>
        <th>Student</th><th>Dept</th><th>Apps</th><th>Offers</th><th>Interviews</th>
        <th>Internships</th><th>FTO</th><th>Ongoing</th><th>Status</th><th></th>
    </tr></thead>
    <tbody>
    @foreach (var s in Model.Students){
    <tr>
        <td class="fw-semibold">@s.Student.FullName</td>
        <td class="small text-muted">@s.Student.Department</td>
        <td>@s.TotalApps</td>
        <td><span class="badge bg-success">@s.Offers</span></td>
        <td>@s.Interviews</td>
        <td>@s.TotalInternships</td>
        <td>@if(s.HasFullTimeOffer){<span class="badge badge-fto"><i class="bi bi-star-fill"></i></span>}else{<span class="text-muted">—</span>}</td>
        <td>@if(s.HasOngoingInternship){<span class="badge bg-success">Yes</span>}else{<span class="text-muted">—</span>}</td>
        <td><span class="badge badge-@s.LatestStatus">@s.LatestStatus</span></td>
        <td><a asp-action="StudentDetails" asp-route-studentId="@s.Student.Id" class="btn btn-xs btn-outline-primary"><i class="bi bi-eye"></i></a></td>
    </tr>}
    </tbody>
</table>
</div></div></div>

<!-- Upcoming Interviews -->
<div class="row g-4">
<div class="col-md-6"><div class="card border-0 shadow-sm"><div class="card-body">
    <h6 class="fw-semibold mb-3"><i class="bi bi-calendar-event text-warning me-2"></i>Upcoming Placement Interviews</h6>
    @if (!Model.UpcomingInterviews.Any()){ <p class="text-muted small">None</p> }
    else { @foreach (var iv in Model.UpcomingInterviews){
    <div class="d-flex justify-content-between mb-2 p-2 bg-light rounded small">
        <div><strong>@iv.JobApplication?.Student?.FullName</strong> — @iv.JobApplication?.CompanyName
            <br/><span class="badge bg-secondary">@iv.InterviewType</span> @iv.InterviewDate.ToString("dd MMM")</div>
        @if (!string.IsNullOrEmpty(iv.MeetingLink)){ <a href="@iv.MeetingLink" target="_blank" class="btn btn-xs btn-outline-primary align-self-center">Join</a> }
    </div> }}
</div></div></div>
<div class="col-md-6"><div class="card border-0 shadow-sm"><div class="card-body">
    <h6 class="fw-semibold mb-3"><i class="bi bi-calendar-event text-info me-2"></i>Upcoming Internship Interviews</h6>
    @if (!Model.UpcomingInternshipInterviews.Any()){ <p class="text-muted small">None</p> }
    else { @foreach (var iv in Model.UpcomingInternshipInterviews){
    <div class="d-flex justify-content-between mb-2 p-2 bg-light rounded small">
        <div><strong>@iv.InternshipApplication?.Student?.FullName</strong> — @iv.InternshipApplication?.CompanyName
            <br/><span class="badge bg-info">@iv.RoundType</span> @iv.InterviewDate.ToString("dd MMM")</div>
    </div> }}
</div></div></div>
</div>
