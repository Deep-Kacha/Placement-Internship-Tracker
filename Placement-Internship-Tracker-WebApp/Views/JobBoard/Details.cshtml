@model PlacementTracker.Models.JobDescription
@{ ViewData["Title"] = "Job Details"; 
   bool hasApplied = ViewBag.HasApplied ?? false;
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left me-1"></i>Back to Board</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm p-2 p-md-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-md-center flex-column flex-md-row mb-4 gap-3">
                    <div>
                        <h3 class="fw-bold mb-1">@Model.Title</h3>
                        <div class="text-muted fs-5"><i class="bi bi-building me-2"></i>@Model.CompanyName</div>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-3">
                        <div class="text-muted small text-uppercase fw-bold mb-1">Job Type</div>
                        <div class="fw-medium">@Model.JobType</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.AnnualCTC)) {
                    <div class="col-6 col-md-3">
                        <div class="text-muted small text-uppercase fw-bold mb-1">Annual CTC</div>
                        <div class="fw-medium text-brand-700">@Model.AnnualCTC</div>
                    </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Stipend)) {
                    <div class="col-6 col-md-3">
                        <div class="text-muted small text-uppercase fw-bold mb-1">Stipend / Month</div>
                        <div class="fw-medium text-brand-700">@Model.Stipend</div>
                    </div>
                    }
                    @if (Model.JobType == "Internship" && !string.IsNullOrEmpty(Model.InternshipDuration)) {
                    <div class="col-6 col-md-3">
                        <div class="text-muted small text-uppercase fw-bold mb-1">Duration</div>
                        <div class="fw-medium">@Model.InternshipDuration</div>
                    </div>
                    }
                    <div class="col-6 col-md-3">
                        <div class="text-muted small text-uppercase fw-bold mb-1">Apply By</div>
                        <div class="fw-medium text-danger">@Model.Deadline.ToString("dd MMM yyyy")</div>
                    </div>
                    @if (Model.DateOfJoining.HasValue) {
                    <div class="col-6 col-md-3">
                        <div class="text-muted small text-uppercase fw-bold mb-1">Joining Date</div>
                        <div class="fw-medium text-success">@Model.DateOfJoining.Value.ToString("dd MMM yyyy")</div>
                    </div>
                    }
                    <div class="col-6 col-md-3">
                        <div class="text-muted small text-uppercase fw-bold mb-1">Location</div>
                        <div class="fw-medium">@(Model.Location ?? "TBD")</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="text-muted small text-uppercase fw-bold mb-1">Eligibility</div>
                        <div class="fw-medium small">@(Model.EligibleBatches ?? "All") / @(Model.EligibleCourses ?? "All")</div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mb-4">
                    @if (!string.IsNullOrEmpty(Model.RegistrationLink)) {
                        <a href="@Model.RegistrationLink" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-link-45deg me-1"></i>External Link ↗</a>
                    }
                    @if (!string.IsNullOrEmpty(Model.DocumentsPath)) {
                        <a href="@Model.DocumentsPath" target="_blank" class="btn btn-sm btn-outline-success"><i class="bi bi-file-earmark-pdf me-1"></i>Download JD</a>
                    }
                </div>

                <hr class="my-4 text-muted">

                <h5 class="fw-bold mb-3">About the Role</h5>
                <p class="text-secondary" style="white-space: pre-wrap">@Model.Description</p>

                @if(!string.IsNullOrWhiteSpace(Model.SelectionProcess)) {
                    <h5 class="fw-bold mb-3 mt-4">Selection Process</h5>
                    <div class="p-3 bg-light rounded text-sm mb-4">@Model.SelectionProcess</div>
                }

                @if(!string.IsNullOrWhiteSpace(Model.Requirements)) {
                    <h5 class="fw-bold mb-3 mt-4">Requirements & Skills</h5>
                    <p class="text-secondary" style="white-space: pre-wrap">@Model.Requirements</p>
                }

                <div class="mt-5 p-4 bg-secondary bg-opacity-10 rounded-3 text-center">
                    @if (hasApplied) {
                        <h5 class="fw-bold text-success mb-2"><i class="bi bi-check-circle-fill me-2"></i>Application Submitted</h5>
                        <p class="text-muted mb-0">You have already applied for this role. Track its status in your dashboard.</p>
                    }
                    else if (DateTime.Today > Model.Deadline) {
                        <h5 class="fw-bold text-danger mb-0"><i class="bi bi-x-circle-fill me-2"></i>Deadline Passed</h5>
                    }
                    else {
                        <form asp-action="Apply" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <h5 class="fw-bold mb-3">Interested in this role?</h5>
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm px-5 rounded-pill" onclick="return confirm('Confirm application submission?')">Apply Now</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
