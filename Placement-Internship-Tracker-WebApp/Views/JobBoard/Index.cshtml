@model IEnumerable<PlacementTracker.Models.JobDescription>
@{ ViewData["Title"] = "Discover Jobs"; 
   var appliedList = ViewBag.AppliedJobIds as HashSet<int?> ?? new HashSet<int?>();
   bool isLocked = ViewBag.IsPlacementLocked ?? false;
   string? selectedCompany = ViewBag.SelectedCompany;
}

@if (isLocked) {
<div class="alert border-0 shadow-sm mb-4 p-4" style="background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);">
    <div class="d-flex align-items-center">
        <div class="me-3">
            <div class="bg-success bg-opacity-25 rounded-circle p-3 d-inline-flex">
                <i class="bi bi-shield-lock-fill text-success fs-3"></i>
            </div>
        </div>
        <div>
            <h5 class="fw-bold text-success mb-1">🎉 Congratulations! You've Been Placed!</h5>
            <p class="mb-0 text-dark">You have been <strong>selected</strong> at <strong>@selectedCompany</strong>. Your application portal is now <strong>locked</strong> — you cannot apply to new opportunities.</p>
        </div>
    </div>
</div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Discover Opportunities</h4>
    <div class="btn-group shadow-sm">
        <a asp-action="Index" asp-route-type="" class="btn btn-outline-secondary @(Context.Request.Query["type"]==""?"active":"")">All</a>
        <a asp-action="Index" asp-route-type="Placement" class="btn btn-outline-secondary @(Context.Request.Query["type"]=="Placement"?"active":"")">Placements</a>
        <a asp-action="Index" asp-route-type="Internship" class="btn btn-outline-secondary @(Context.Request.Query["type"]=="Internship"?"active":"")">Internships</a>
    </div>
</div>

<div class="row g-4">
    @if(!Model.Any()) {
        <div class="col-12 text-center py-5 text-muted">No active job postings right now. Check back later!</div>
    }
    @foreach(var jd in Model) {
        bool isApplied = appliedList.Contains(jd.Id);
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm hover-shadow transition-all">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between mb-3">
                        <div class="bg-light rounded p-2 text-primary">
                            <i class="bi bi-buildings fs-4"></i>
                        </div>
                        <span class="badge bg-light text-dark border align-self-start">@jd.JobType</span>
                    </div>
                    <h5 class="fw-bold mb-1">@jd.Title</h5>
                    <p class="text-muted small fw-medium mb-3">@jd.CompanyName</p>
                    
                    <div class="mb-4">
                        <div class="d-flex align-items-center text-brand-700 fw-bold mb-1">
                            <i class="bi bi-cash-stack me-2"></i>
                            @if (!string.IsNullOrEmpty(jd.AnnualCTC)) { <span>@jd.AnnualCTC (CTC)</span> }
                            else if (!string.IsNullOrEmpty(jd.Stipend)) { <span>@jd.Stipend (Stipend)</span> }
                            else { <span class="text-muted">Competitive</span> }
                        </div>
                        <div class="d-flex flex-wrap gap-2 text-muted x-small">
                            <span title="Deadline"><i class="bi bi-calendar-event me-1 text-danger"></i>@jd.Deadline.ToString("dd MMM")</span>
                            <span title="Location"><i class="bi bi-geo-alt me-1 text-secondary"></i>@(jd.Location ?? "TBD")</span>
                        </div>
                    </div>
                    
                    @{ bool isClosed = DateTime.Today > jd.Deadline; }
                    @if (isLocked) {
                        <a asp-action="Details" asp-route-id="@jd.Id" class="btn w-100 fw-semibold btn-light border text-secondary disabled">
                            <i class="bi bi-lock-fill me-1"></i>Locked
                        </a>
                    } else if (isApplied) {
                        <a asp-action="Details" asp-route-id="@jd.Id" class="btn w-100 fw-semibold btn-light border text-success disabled">
                            Applied ✓
                        </a>
                    } else if (isClosed) {
                        <a asp-action="Details" asp-route-id="@jd.Id" class="btn w-100 fw-semibold btn-light border text-danger">
                            Closed (View Details)
                        </a>
                    } else {
                        <a asp-action="Details" asp-route-id="@jd.Id" class="btn w-100 fw-semibold btn-primary">
                            View Details & Apply
                        </a>
                    }
                </div>
            </div>
        </div>
    }
</div>
