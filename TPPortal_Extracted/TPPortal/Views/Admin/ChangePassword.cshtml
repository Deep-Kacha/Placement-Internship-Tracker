@{ ViewData["Title"] = "Change Password"; }

<div class="w-full">
    <h1 class="text-2xl md:text-3xl font-bold text-red-600">Change Password</h1>
    <p class="text-gray-600 mb-6 md:mb-8 text-sm md:text-base">Update your account password for better security.</p>

    <div class="flex justify-center">
        <form onsubmit="return validateChangePassword(event)" class="bg-[#d8cfc3] p-6 md:p-8 rounded-xl shadow-md w-full max-w-md">
            <div class="mb-5">
                <label class="block text-sm mb-1">Current Password</label>
                <div class="relative">
                    <input type="password" id="currentPassword" name="current" placeholder="Enter current password" class="w-full p-3 rounded-lg border outline-none" oninput="validateFieldRealtime('current')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'currentPassword')">Show</button>
                </div>
                <p id="currentError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <div class="mb-5">
                <label class="block text-sm mb-1">New Password</label>
                <div class="relative">
                    <input type="password" id="newPassword" name="new" placeholder="Enter new password" class="w-full p-3 rounded-lg border outline-none" oninput="validateFieldRealtime('new')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'newPassword')">Show</button>
                </div>
                <p id="newError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <div class="mb-5">
                <label class="block text-sm mb-1">Confirm New Password</label>
                <div class="relative">
                    <input type="password" id="confirmPassword" name="confirm" placeholder="Re-Enter new password" class="w-full p-3 rounded-lg border outline-none" oninput="validateFieldRealtime('confirm')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'confirmPassword')">Show</button>
                </div>
                <p id="confirmError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <div class="bg-gray-100 p-4 rounded-lg mb-5 text-sm">
                <p class="font-semibold mb-2">Password requirements:</p>
                <ul class="space-y-1 text-gray-600 list-none p-0">
                    <li>✔ At least 8 characters long</li>
                    <li>✔ Contains uppercase and lowercase letters</li>
                    <li>✔ Contains at least one number</li>
                    <li>✔ Contains at least one special character</li>
                </ul>
            </div>

            <!-- Forgot Password -->
            <div class="text-right text-sm mb-4">
                <a href="/AdminForgotPassword" class="text-gray-700 hover:underline no-underline cursor-pointer">Forgot Password?</a>
            </div>

            <!-- Update Button -->
            <button type="submit" class="w-full bg-red-600 text-white py-3 rounded-lg mb-3 hover:bg-red-700 border-none cursor-pointer">Update Password</button>

            <!-- Cancel -->
            <button type="button" onclick="history.back()" class="w-full border py-3 rounded-lg hover:bg-gray-50 cursor-pointer bg-transparent">Cancel</button>
        </form>
    </div>
</div>
