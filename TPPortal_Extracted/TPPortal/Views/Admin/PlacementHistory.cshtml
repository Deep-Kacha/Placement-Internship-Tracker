@{ ViewData["Title"] = "Placement History"; }

<div class="w-full">
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-2xl md:text-3xl font-bold text-red-600">Placement History</h1>
        <p class="text-gray-600 text-sm md:text-base">Manage And maintain A Placement Records</p>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl shadow overflow-x-auto">
        <table class="w-full text-left min-w-[900px]">
            <thead class="bg-gray-200">
                <tr>
                    <th class="p-4">Company Name</th>
                    <th class="p-4">Job Role</th>
                    <th class="p-4">Package</th>
                    <th class="p-4 text-center">Selected Students</th>
                    <th class="p-4">Offer Date</th>
                    <th class="p-4">Joining Date</th>
                    <th class="p-4">Status</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var placements = new[] {
                        new { Id=1, Company="Multiicon", Role="PHP Developer", Package="₹3.6 LPA", OfferDate="Jan 12, 2026", JoiningDate="July 12, 2026", Selected=5, StatusClass="bg-green-100 text-green-700", StatusLabel="Completed" },
                        new { Id=2, Company="Gateway Group", Role="Software Engineer", Package="₹4.5 LPA", OfferDate="-", JoiningDate="-", Selected=0, StatusClass="bg-blue-100 text-blue-700", StatusLabel="Interview Scheduled" },
                        new { Id=3, Company="Infinity IT", Role="React Native Developer", Package="₹5 LPA", OfferDate="-", JoiningDate="-", Selected=0, StatusClass="bg-indigo-100 text-indigo-700", StatusLabel="On Hold" },
                        new { Id=4, Company="TCS Ltd", Role="Software Development Engineer", Package="₹8 LPA", OfferDate="-", JoiningDate="-", Selected=12, StatusClass="bg-blue-100 text-blue-600", StatusLabel="Applied" },
                        new { Id=5, Company="Simform", Role="DotNet Developer", Package="₹5.5 LPA", OfferDate="-", JoiningDate="-", Selected=0, StatusClass="bg-red-100 text-red-600", StatusLabel="Rejected" },
                        new { Id=6, Company="TatvaSoft", Role="Java Developer", Package="₹6.5 LPA", OfferDate="Feb 20, 2026", JoiningDate="Aug 01, 2026", Selected=3, StatusClass="bg-blue-100 text-blue-700", StatusLabel="Approved" },
                        new { Id=7, Company="Radixweb", Role="QA Engineer", Package="₹4.8 LPA", OfferDate="-", JoiningDate="-", Selected=0, StatusClass="bg-indigo-100 text-indigo-600", StatusLabel="In Progress" },
                        new { Id=8, Company="Wipro", Role="System Analyst", Package="₹6 LPA", OfferDate="-", JoiningDate="-", Selected=0, StatusClass="bg-blue-100 text-blue-600", StatusLabel="Applied" },
                        new { Id=9, Company="Capgemini", Role="Project Engineer", Package="₹4 LPA", OfferDate="Mar 15, 2026", JoiningDate="Sep 01, 2026", Selected=8, StatusClass="bg-green-100 text-green-700", StatusLabel="Completed" },
                        new { Id=10, Company="Tech Mahindra", Role="Analyst", Package="₹3.8 LPA", OfferDate="-", JoiningDate="-", Selected=0, StatusClass="bg-blue-100 text-blue-700", StatusLabel="Interview Scheduled" },
                        new { Id=11, Company="HCL Tech", Role="Graduate Engineer Trainee", Package="₹4.25 LPA", OfferDate="-", JoiningDate="-", Selected=0, StatusClass="bg-indigo-100 text-indigo-700", StatusLabel="On Hold" },
                        new { Id=12, Company="Accenture", Role="Software Associate", Package="₹4.5 LPA", OfferDate="-", JoiningDate="-", Selected=0, StatusClass="bg-red-100 text-red-600", StatusLabel="Rejected" }
                    };
                }
                @foreach (var p in placements)
                {
                    <tr class="bg-white border-t hover:bg-gray-50">
                        <td class="p-4 flex items-center gap-3 font-semibold">
                            <div class="bg-blue-200 text-blue-700 w-10 h-10 flex items-center justify-center rounded-lg">
                                <i class="fas fa-building"></i>
                            </div>
                            @p.Company
                        </td>
                        <td class="p-4">@p.Role</td>
                        <td class="p-4 font-semibold">@p.Package</td>
                        <td class="p-4 text-center font-semibold text-gray-700">@p.Selected</td>
                        <td class="p-4">@p.OfferDate</td>
                        <td class="p-4">@p.JoiningDate</td>
                        <td class="p-4">
                            <span class="px-3 py-1 rounded-full text-sm @p.StatusClass">
                                @p.StatusLabel
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
