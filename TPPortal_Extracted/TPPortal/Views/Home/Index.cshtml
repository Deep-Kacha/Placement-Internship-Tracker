@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<!-- Header -->
@await Html.PartialAsync("_Header")

<!-- Hero Section -->
<section id="home" class="relative min-h-[520px] flex items-center bg-cover bg-left" style="background-image: url('/images/hero.jpg')">
    <div class="absolute inset-0 bg-white/50"></div>
    <div class="relative max-w-7xl px-8 lg:px-16 py-[11.25rem]">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
            Welcome to Training <br /> &amp; Placement Cell
        </h1>
        <p class="mt-3 text-gray-600 font-semibold text-lg tracking-wide uppercase">RK University</p>
        <p class="mt-4 max-w-lg text-gray-700">
            Empowering students to achieve their career aspirations through industry connections and comprehensive placement support.
        </p>
        <a href="/Register" class="mt-6 inline-block bg-red-600 text-white px-6 py-3 rounded-lg hover:bg-red-700 transition no-underline">
            Register as Student →
        </a>
    </div>
</section>

<!-- Stats Section -->
<section id="placements" class="py-20 bg-gray-100">
    <div class="max-w-6xl mx-auto grid md:grid-cols-4 gap-10">
        <div class="bg-[#d9d1c7] p-6 text-center rounded-lg shadow">
            <div class="text-red-600 text-2xl font-bold">850+</div>
            <p class="text-gray-700 mt-2">Registered Students</p>
        </div>
        <div class="bg-[#d9d1c7] p-6 text-center rounded-lg shadow">
            <div class="text-red-600 text-2xl font-bold">92%</div>
            <p class="text-gray-700 mt-2">Placed Students</p>
        </div>
        <div class="bg-[#d9d1c7] p-6 text-center rounded-lg shadow">
            <div class="text-red-600 text-2xl font-bold">120+</div>
            <p class="text-gray-700 mt-2">Recruiters</p>
        </div>
        <div class="bg-[#d9d1c7] p-6 text-center rounded-lg shadow">
            <div class="text-red-600 text-2xl font-bold">12 LPA</div>
            <p class="text-gray-700 mt-2">Highest Package</p>
        </div>
    </div>
</section>

<!-- Placement Policy -->
<section class="bg-gray-100 py-5 px-6">
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-800">Placement Policy</h2>
            <p class="text-gray-500 mt-2">Understanding our placement process and guidelines</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <!-- Eligibility -->
            <div class="bg-white rounded-xl shadow-md border-l-4 border-red-500 p-8">
                <div class="flex items-center gap-3 mb-5">
                    <div class="bg-red-500 text-white p-2 rounded-full"><i class="fas fa-check-circle"></i></div>
                    <h3 class="text-xl font-semibold text-red-600">Eligibility Criteria</h3>
                </div>
                <ul class="space-y-3 text-gray-700">
                    <li class="flex gap-2"><i class="fas fa-check-circle text-green-500 mt-1"></i> Minimum CGPA of 6.5 for most recruiters</li>
                    <li class="flex gap-2"><i class="fas fa-check-circle text-green-500 mt-1"></i> No active backlogs at the time of placement</li>
                    <li class="flex gap-2"><i class="fas fa-check-circle text-green-500 mt-1"></i> Regular attendance (minimum 75%)</li>
                    <li class="flex gap-2"><i class="fas fa-check-circle text-green-500 mt-1"></i> Valid and updated resume uploaded on portal</li>
                    <li class="flex gap-2"><i class="fas fa-check-circle text-green-500 mt-1"></i> Completion of mandatory training programs</li>
                </ul>
            </div>

            <!-- Rules -->
            <div class="bg-white rounded-xl shadow-md border-l-4 border-red-500 p-8">
                <div class="flex items-center gap-3 mb-5">
                    <div class="bg-red-500 text-white p-2 rounded-full"><i class="fas fa-file-alt"></i></div>
                    <h3 class="text-xl font-semibold text-red-600">Placement Rules</h3>
                </div>
                <ul class="space-y-3 text-gray-700">
                    <li class="flex gap-2"><span class="w-2 h-2 bg-red-500 rounded-full mt-2 shrink-0"></span> Students can apply to multiple companies</li>
                    <li class="flex gap-2"><span class="w-2 h-2 bg-red-500 rounded-full mt-2 shrink-0"></span> Once placed, student cannot appear for further drives</li>
                    <li class="flex gap-2"><span class="w-2 h-2 bg-red-500 rounded-full mt-2 shrink-0"></span> Attendance in pre-placement talks is mandatory</li>
                    <li class="flex gap-2"><span class="w-2 h-2 bg-red-500 rounded-full mt-2 shrink-0"></span> Professional attire required during interviews</li>
                    <li class="flex gap-2"><span class="w-2 h-2 bg-red-500 rounded-full mt-2 shrink-0"></span> No malpractice or misrepresentation allowed</li>
                </ul>
            </div>
        </div>

        <!-- Selection Process -->
        <div class="mt-12 bg-gradient-to-r from-red-800 to-red-600 rounded-xl shadow-lg p-10 text-white">
            <div class="flex items-center gap-3 mb-8">
                <div class="bg-white text-red-600 p-2 rounded-full"><i class="fas fa-list-check"></i></div>
                <h3 class="text-xl font-semibold">Selection Process</h3>
            </div>
            <div class="grid md:grid-cols-4 gap-8 text-center">
                <div>
                    <div class="bg-white text-blue-900 font-bold w-14 h-14 flex items-center justify-center rounded-full mx-auto mb-3">1</div>
                    <h4 class="font-semibold">Registration</h4>
                    <p class="text-sm text-gray-200">Apply through portal</p>
                </div>
                <div>
                    <div class="bg-white text-blue-900 font-bold w-14 h-14 flex items-center justify-center rounded-full mx-auto mb-3">2</div>
                    <h4 class="font-semibold">Aptitude Test</h4>
                    <p class="text-sm text-gray-200">Online/Offline exam</p>
                </div>
                <div>
                    <div class="bg-white text-blue-900 font-bold w-14 h-14 flex items-center justify-center rounded-full mx-auto mb-3">3</div>
                    <h4 class="font-semibold">Technical Round</h4>
                    <p class="text-sm text-gray-200">Technical interview</p>
                </div>
                <div>
                    <div class="bg-white text-blue-900 font-bold w-14 h-14 flex items-center justify-center rounded-full mx-auto mb-3">4</div>
                    <h4 class="font-semibold">HR Round</h4>
                    <p class="text-sm text-gray-200">Final interview</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Recruiters -->
<section id="recruiters" class="py-[4.5rem] bg-gray-100 overflow-hidden">
    <div class="text-center mb-14">
        <h2 class="text-3xl font-bold text-gray-800">Our Top Recruiters</h2>
        <p class="text-gray-500 mt-2">Trusted by leading organizations worldwide</p>
    </div>
    <div class="flex animate-scroll gap-20 w-max px-20">
        @foreach (var img in new[] { "gateway.jpg", "multiicon.jpg", "qtonz.png", "rkit.jpg", "infinity.jpg", "tcs.jpg", "rtcamp.png", "gateway.jpg", "multiicon.jpg", "qtonz.png", "rkit.jpg", "infinity.jpg", "tcs.jpg", "rtcamp.png" })
        {
            <div class="bg-[#d8d1c7] flex items-center justify-center rounded-lg shadow-md px-[6.25rem] py-20 min-w-[200px] h-[100px]">
                <img src="~/images/@img" alt="company" class="max-h-[7.5rem] object-contain" />
            </div>
        }
    </div>
</section>

<!-- About Section -->
<section id="about" class="bg-gray-100 py-24 px-6">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold text-gray-900">About Training &amp; Placement Cell</h2>
            <p class="text-gray-600 mt-4 max-w-3xl mx-auto">
                Our mission is to bridge the gap between academia and industry by providing students with world-class training and connecting them with leading employers.
            </p>
        </div>
        <div class="grid md:grid-cols-2 gap-16 items-center">
            <div class="w-full">
                <img src="~/images/about.png" alt="Training and Placement" class="w-full h-[320px] object-cover rounded-xl shadow-lg" />
            </div>
            <div class="space-y-10">
                <div class="flex items-start gap-5">
                    <div class="bg-red-600 text-white p-3 rounded-full"><i class="fas fa-graduation-cap"></i></div>
                    <div>
                        <h3 class="text-lg font-semibold text-gray-800">Comprehensive Training</h3>
                        <p class="text-gray-600 mt-1 text-sm leading-relaxed">Industry-oriented training programs covering technical skills, soft skills, and aptitude development.</p>
                    </div>
                </div>
                <div class="flex items-start gap-5">
                    <div class="bg-red-600 text-white p-3 rounded-full"><i class="fas fa-handshake"></i></div>
                    <div>
                        <h3 class="text-lg font-semibold text-gray-800">Industry Partnerships</h3>
                        <p class="text-gray-600 mt-1 text-sm leading-relaxed">Strong relationships with 250+ leading companies across diverse sectors and industries.</p>
                    </div>
                </div>
                <div class="flex items-start gap-5">
                    <div class="bg-red-600 text-white p-3 rounded-full"><i class="fas fa-chart-line"></i></div>
                    <div>
                        <h3 class="text-lg font-semibold text-gray-800">Career Development</h3>
                        <p class="text-gray-600 mt-1 text-sm leading-relaxed">Personalized career counseling, resume building, and interview preparation support.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Footer -->
@await Html.PartialAsync("_Footer")
