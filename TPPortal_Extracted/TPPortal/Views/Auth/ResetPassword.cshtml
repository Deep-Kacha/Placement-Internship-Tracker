@{ ViewData["Title"] = "Reset Password"; }

<div class="min-h-screen flex flex-col bg-gray-200">
    <div class="flex-grow flex flex-col items-center justify-center px-4">

        <!-- Title -->
        <h1 class="text-2xl md:text-3xl font-bold">Reset Password</h1>
        <p class="text-gray-600 text-sm mb-8">Create a new secure password for your account.</p>

        <!-- Card -->
        <form onsubmit="return validateResetPassword(event)" class="bg-[#d8cfc2] p-8 rounded-xl shadow-lg w-full max-w-md">
            <!-- New Password -->
            <div class="mb-4 relative">
                <label class="text-sm font-medium">New Password</label>
                <input type="password" id="resetNewPassword" placeholder="Enter new password" class="w-full mt-1 p-2 rounded-md border" oninput="validateFieldRealtime('resetNew')" />
                <button type="button" class="absolute right-3 top-9 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'resetNewPassword')">Show</button>
                <p id="resetNewError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Confirm Password -->
            <div class="mb-4 relative">
                <label class="text-sm font-medium">Confirm Password</label>
                <input type="password" id="resetConfirmPassword" placeholder="Re-enter new password" class="w-full mt-1 p-2 rounded-md border" oninput="validateFieldRealtime('resetConfirm')" />
                <button type="button" class="absolute right-3 top-9 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'resetConfirmPassword')">Show</button>
                <p id="resetConfirmError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Password Rules -->
            <div class="bg-gray-100 rounded-md p-4 mb-6 text-sm">
                <p class="font-medium mb-2">Password must contain:</p>
                <ul class="space-y-1 text-gray-700 list-none p-0">
                    <li>✔ At least 8 characters</li>
                    <li>✔ One uppercase letter</li>
                    <li>✔ One lowercase letter</li>
                    <li>✔ One number</li>
                </ul>
            </div>

            <!-- Reset Button -->
            <button type="submit" class="w-full bg-red-600 text-white py-2 rounded-md hover:bg-red-700 transition mb-4 border-none cursor-pointer font-medium">Reset Password</button>

            <!-- Back to Login -->
            <div class="text-center">
                <a href="/Authentication/login" class="text-sm hover:underline text-black no-underline">← Back to Login</a>
            </div>
        </form>
    </div>
</div>
