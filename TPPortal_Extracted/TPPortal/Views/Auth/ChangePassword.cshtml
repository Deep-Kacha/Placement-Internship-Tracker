@{ ViewData["Title"] = "Change Password"; }

<div class="min-h-screen flex flex-col bg-gray-200">
    <div class="flex-grow flex flex-col items-center justify-center px-4">

        <!-- Title -->
        <h1 class="text-2xl md:text-3xl font-bold">Change Password</h1>
        <p class="text-gray-600 text-sm mb-8">Update your account password for better security.</p>

        <!-- Card -->
        <form onsubmit="return validateChangePassword(event)" class="bg-[#d8cfc2] p-8 rounded-xl shadow-lg w-full max-w-md">

            <!-- Current Password -->
            <div class="mb-4 relative">
                <label class="text-sm font-medium">Current Password</label>
                <input type="password" id="currentPassword" placeholder="Enter current password" class="w-full mt-1 p-2 rounded-md border" oninput="validateFieldRealtime('current')" />
                <button type="button" class="absolute right-3 top-9 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'currentPassword')">Show</button>
                <p id="currentError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- New Password -->
            <div class="mb-4 relative">
                <label class="text-sm font-medium">New Password</label>
                <input type="password" id="newPassword" placeholder="Enter new password" class="w-full mt-1 p-2 rounded-md border" oninput="validateFieldRealtime('new')" />
                <button type="button" class="absolute right-3 top-9 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'newPassword')">Show</button>
                <p id="newError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Confirm New Password -->
            <div class="mb-4 relative">
                <label class="text-sm font-medium">Confirm New Password</label>
                <input type="password" id="confirmPassword" placeholder="Re-enter new password" class="w-full mt-1 p-2 rounded-md border" oninput="validateFieldRealtime('confirm')" />
                <button type="button" class="absolute right-3 top-9 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'confirmPassword')">Show</button>
                <p id="confirmError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Password Requirements (static checkmarks like React) -->
            <div class="bg-gray-100 rounded-md p-4 mb-6 text-sm">
                <p class="font-medium mb-2">Password requirements:</p>
                <ul class="space-y-1 text-gray-700 list-none p-0">
                    <li>✔ At least 8 characters long</li>
                    <li>✔ Contains uppercase and lowercase letters</li>
                    <li>✔ Contains at least one number</li>
                    <li>✔ Contains at least one special character</li>
                </ul>
            </div>

            <!-- Buttons -->
            <button type="submit" class="w-full bg-red-600 text-white py-2 rounded-md hover:bg-red-700 transition mb-3 border-none cursor-pointer font-medium">Update Password</button>
            <button type="button" onclick="history.back()" class="w-full border border-black py-2 rounded-md hover:bg-gray-100 transition cursor-pointer bg-transparent font-medium">Cancel</button>
        </form>
    </div>
</div>
