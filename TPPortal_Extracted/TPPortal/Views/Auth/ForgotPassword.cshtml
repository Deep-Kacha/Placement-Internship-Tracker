@{ ViewData["Title"] = "Forgot Password"; }

<div class="min-h-screen flex flex-col bg-gray-200">
    <div class="flex-grow flex flex-col items-center justify-center px-4 py-12">
        <div class="text-center mb-8">
            <h1 class="text-2xl md:text-3xl font-bold">RK University <br /> Training &amp; Placement Cell</h1>
        </div>

        <form onsubmit="return validateForgotPassword(event)" class="bg-[#d8cfc2] p-8 rounded-xl shadow-lg w-full max-w-md">
            <h2 class="text-xl font-bold text-center mb-2">Forgot Password</h2>
            <p class="text-center text-sm text-gray-600 mb-6">Reset your account password</p>

            <!-- Email -->
            <div class="mb-4">
                <label class="text-sm font-medium">Registered Email Address</label>
                <div class="relative mt-1">
                    <input type="email" id="forgotEmail" placeholder="Enter your college email" class="w-full p-2 rounded-md border" oninput="validateFieldRealtime('email')" />
                </div>
                <p id="emailError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- New Password -->
            <div class="mb-4">
                <label class="text-sm font-medium">New Password</label>
                <div class="relative mt-1">
                    <input type="password" id="newPassword" placeholder="Enter new password" class="w-full p-2 rounded-md border" oninput="validateFieldRealtime('new')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'newPassword')">Show</button>
                </div>
                <p id="newError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Confirm Password -->
            <div class="mb-4">
                <label class="text-sm font-medium">Confirm Password</label>
                <div class="relative mt-1">
                    <input type="password" id="confirmPassword" placeholder="Re-enter new password" class="w-full p-2 rounded-md border" oninput="validateFieldRealtime('confirm')" />
                    <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-gray-600 bg-transparent border-none cursor-pointer" onclick="togglePasswordText(this, 'confirmPassword')">Show</button>
                </div>
                <p id="confirmError" class="text-red-500 text-xs mt-1 hidden"></p>
            </div>

            <!-- Password Rules (static like React) -->
            <div class="bg-gray-100 rounded-md p-4 mb-6 text-sm">
                <p class="font-medium mb-2">Password must contain:</p>
                <ul class="space-y-1 text-gray-600 list-none p-0">
                    <li>✔ At least 8 characters</li>
                    <li>✔ One uppercase letter</li>
                    <li>✔ One lowercase letter</li>
                    <li>✔ One number</li>
                </ul>
            </div>

            <!-- Buttons -->
            <button type="submit" class="w-full bg-red-600 text-white py-2 rounded-md hover:bg-red-700 transition mb-3 border-none cursor-pointer font-medium">Confirm Password</button>
            <button type="button" onclick="history.back()" class="w-full border border-black py-2 rounded-md hover:bg-gray-100 transition cursor-pointer bg-transparent font-medium">Cancel</button>
        </form>
    </div>
</div>
