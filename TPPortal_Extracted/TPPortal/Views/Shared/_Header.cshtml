        <div class="flex-shrink-0">
            <img src="~/images/logo.png" alt="RK University" class="h-14" />
        </div>

        <!-- CENTER: NAVIGATION -->
        <nav class="hidden md:flex flex-1 justify-center space-x-10 text-gray-800 font-medium">
